.coach-tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 68px;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  display: flex;
  box-shadow: 0 -6px 20px rgba(31, 41, 51, 0.06);
  z-index: 999;
}

.coach-tab-bar-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: rgba(31, 41, 51, 0.06);
  transform: scaleY(0.5);
}

.coach-tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.coach-tab-icon {
  width: 23px;
  height: 23px;
  margin-bottom: 4px;
}

.coach-tab-text {
  font-size: 11px;
  line-height: 14px;
  color: #c7ced6;
  font-weight: 600;
}

.coach-tab-text.is-active {
  color: #35c66b;
}
