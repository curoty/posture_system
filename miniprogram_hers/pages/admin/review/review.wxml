<view class="page">
  <view class="page-header">
    <text class="header-title">认证审核</text>
  </view>

  <scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="container">
      <view wx:if="{{loading}}" class="loading-area">
        <text class="loading-text">加载中...</text>
      </view>

      <view wx:elif="{{pendingList.length === 0}}" class="empty-area">
        <text class="empty-text">暂无待审核申请</text>
      </view>

      <view wx:else class="list-area">
        <view wx:for="{{pendingList}}" wx:key="_id" class="list-item" bindtap="viewDetail" data-index="{{index}}">
          <view class="item-header">
            <text class="item-name">{{item.name || '未设置'}}</text>
            <text class="item-time">{{formatDate(item.applyTime)}}</text>
          </view>
          <view class="item-phone">
            <text class="phone-label">手机号：</text>
            <text class="phone-value">{{item.phone || '未绑定'}}</text>
          </view>
          <view class="item-action">
            <text class="action-text">查看详情 →</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{showDetail}}" class="detail-modal-mask" bindtap="closeDetail">
    <view class="detail-modal" catchtap="">
      <view class="detail-header">
        <text class="detail-title">认证详情</text>
        <view class="detail-close" bindtap="closeDetail">
          <text class="close-text">×</text>
        </view>
      </view>

      <scroll-view class="detail-body" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="detail-info">
          <view class="info-row">
            <text class="info-label">姓名</text>
            <text class="info-value">{{currentItem.name || '未设置'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">手机号</text>
            <text class="info-value">{{currentItem.phone || '未绑定'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">申请时间</text>
            <text class="info-value">{{formatDate(currentItem.applyTime)}}</text>
          </view>
        </view>

        <view class="detail-section">
          <text class="section-title">身份证正面</text>
          <image wx:if="{{currentItem.certificationMaterials && currentItem.certificationMaterials.idCardFront}}" class="section-image" src="{{currentItem.certificationMaterials.idCardFront}}" mode="widthFix" />
          <text wx:else class="section-empty">未上传</text>
        </view>

        <view class="detail-section">
          <text class="section-title">身份证反面</text>
          <image wx:if="{{currentItem.certificationMaterials && currentItem.certificationMaterials.idCardBack}}" class="section-image" src="{{currentItem.certificationMaterials.idCardBack}}" mode="widthFix" />
          <text wx:else class="section-empty">未上传</text>
        </view>

        <view class="detail-section">
          <text class="section-title">资质证明</text>
          <view wx:if="{{currentItem.certificationMaterials && currentItem.certificationMaterials.certificates && currentItem.certificationMaterials.certificates.length > 0}}" class="certificates-list">
            <image wx:for="{{currentItem.certificationMaterials.certificates}}" wx:key="index" class="certificate-image" src="{{item}}" mode="widthFix" />
          </view>
          <text wx:else class="section-empty">未上传</text>
        </view>

        <view class="detail-section">
          <text class="section-title">审核备注</text>
          <textarea class="remark-input" placeholder="请输入审核备注（拒绝时必填）" value="{{remark}}" bindinput="onRemarkInput" />
        </view>
      </scroll-view>

      <view class="detail-footer">
        <button class="detail-btn reject" bindtap="reject">拒绝</button>
        <button class="detail-btn approve" bindtap="approve">通过</button>
      </view>
    </view>
  </view>
</view>
