page {
  background: #f5f7fa;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header-bar {
  padding: 32rpx 28rpx 24rpx;
  background: linear-gradient(135deg, #3b4d61 0%, #4a6580 100%);
}

.header-title {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #ffffff;
}

.header-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.state-card {
  margin: 32rpx 24rpx;
  padding: 48rpx 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.error-card {
  border: 2rpx solid #ffd8d6;
}

.state-text {
  font-size: 24rpx;
  color: #8a98a8;
}

.error-text {
  color: #ea5b52;
}

.retry-btn {
  margin-top: 18rpx;
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #35c66b;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.list-container {
  margin: 24rpx;
}

.list-header {
  display: flex;
  align-items: center;
  padding: 0 16rpx 16rpx;
  gap: 12rpx;
}

.col-name {
  flex: 2;
  font-size: 22rpx;
  color: #8a98a8;
  font-weight: 600;
}

.col-phone {
  flex: 1.5;
  font-size: 22rpx;
  color: #8a98a8;
  font-weight: 600;
}

.col-role {
  flex: 0.8;
  font-size: 22rpx;
  color: #8a98a8;
  font-weight: 600;
  text-align: center;
}

.col-action {
  flex: 1.2;
  font-size: 22rpx;
  color: #8a98a8;
  font-weight: 600;
  text-align: center;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 12rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.user-info {
  flex: 2;
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #eaf4ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 28rpx;
  font-weight: 700;
  color: #4a6580;
}

.user-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2933;
  line-height: 1.3;
}

.user-phone {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8a98a8;
}

.user-date {
  margin-top: 2rpx;
  font-size: 20rpx;
  color: #b0bcc8;
}

.user-tags {
  flex: 0.8;
  display: flex;
  justify-content: center;
}

.role-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.role-coach {
  background: #eef7ff;
  color: #49bdf5;
}

.role-student {
  background: #eafbf2;
  color: #35c66b;
}

.action-btn {
  flex: 1.2;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 999rpx;
  border: none;
}

.action-promote {
  background: #eef7ff;
  color: #49bdf5;
}

.action-demote {
  background: #fef2f0;
  color: #f45b5b;
}

.action-btn[disabled] {
  opacity: 0.5;
}

.loading-more {
  padding: 24rpx;
  text-align: center;
}
