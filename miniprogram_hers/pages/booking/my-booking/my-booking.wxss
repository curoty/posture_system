page {
  background: linear-gradient(180deg, #eaf8ff 0%, #f5fbff 28%, #f7fbff 46%, #ffffff 100%);
}

.page {
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
}

.header {
  padding: 32rpx 28rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #35c66b 0%, #59d892 52%, #6fd8c0 100%);
  box-shadow: 0 16rpx 36rpx rgba(53, 198, 107, 0.18);
}

.header-eyebrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.header-title {
  display: block;
  margin-top: 10rpx;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.header-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.88);
}

.section-card {
  margin-top: 22rpx;
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(22, 55, 94, 0.06);
}

.state-card {
  margin-top: 22rpx;
  padding: 48rpx 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(22, 55, 94, 0.06);
  text-align: center;
}

.state-text {
  font-size: 24rpx;
  color: #8a98a8;
}

.error-card {
  border: 2rpx solid #ffd8d6;
}

.error-text {
  color: #ea5b52;
}

.retry-btn {
  margin-top: 18rpx;
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #35c66b;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2933;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #8a98a8;
}

.booking-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.booking-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f9fcff;
  border: 2rpx solid #edf4f8;
}

.booking-top {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
}

.date-badge {
  width: 116rpx;
  min-height: 124rpx;
  padding: 18rpx 12rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ecfff2 0%, #ddf7e8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.date-badge-day {
  font-size: 30rpx;
  font-weight: 800;
  color: #1f2933;
}

.date-badge-week {
  font-size: 22rpx;
  color: #35c66b;
  font-weight: 700;
}

.booking-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.booking-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.booking-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #1f2933;
}

.booking-status {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
}

.status-pending {
  background: #eafbf2;
  color: #35c66b;
}

.status-active {
  background: #eef7ff;
  color: #49bdf5;
}

.status-completed {
  background: #f1f4f7;
  color: #8a98a8;
}

.status-cancelled {
  background: #fff1f0;
  color: #f45b5b;
}

.booking-time {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2933;
}

.booking-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8a98a8;
}

.cancel-btn {
  width: 100%;
  height: 74rpx;
  line-height: 74rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #fff3f2;
  color: #f45b5b;
  border: 2rpx solid #ffd7d4;
  font-size: 24rpx;
  font-weight: 700;
}
