.mall-page {
  min-height: 100vh;
  padding: 20rpx 32rpx 170rpx;
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f7fafc;
}

/* 搜索行 */
.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.search-box {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f4f7fa;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.search-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 76rpx;
  color: #1f2933;
  font-size: 26rpx;
}

.search-placeholder {
  color: #a6b0ba;
}

.search-btn {
  min-width: 120rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #1989fa;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 76rpx;
  text-align: center;
  font-weight: 700;
  padding: 0 24rpx;
  flex-shrink: 0;
}

/* 工具栏：数量 + 筛选 */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.toolbar-count {
  font-size: 26rpx;
  color: #1f2933;
  font-weight: 700;
}

.count-num {
  color: #35c66b;
  font-weight: 800;
}

.filter-picker {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #e8edf2;
  font-size: 24rpx;
  color: #4b5563;
}

.error-tip {
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  color: #b42318;
  background: #fff1f0;
  border: 1rpx solid #ffccc7;
  font-size: 24rpx;
}

/* 促销横幅 */
.promo-banner {
  position: relative;
  height: 240rpx;
  margin-bottom: 26rpx;
  padding: 24rpx 24rpx 24rpx 28rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: 0 12rpx 26rpx rgba(73, 189, 245, 0.16);
}

.promo-bg,
.promo-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.promo-mask {
  background: linear-gradient(90deg, rgba(33, 168, 95, 0.9) 0%, rgba(53, 198, 107, 0.72) 42%, rgba(73, 189, 245, 0.16) 100%);
}

.promo-copy {
  position: relative;
  z-index: 2;
  width: 56%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.promo-title {
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 800;
}

.promo-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  font-weight: 600;
}

.promo-btn {
  margin-top: 26rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #ffd765;
  color: #7b5a00;
  font-size: 22rpx;
  font-weight: 800;
}

.promo-kid {
  position: absolute;
  right: -4rpx;
  bottom: -6rpx;
  width: 240rpx;
  height: 232rpx;
  z-index: 2;
}

/* 分类行 */
.category-grid {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.category-item {
  width: 20%;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  border-radius: 18rpx;
  padding: 8rpx 0;
  box-sizing: border-box;
}

.category-item.active {
  background: #eafbf2;
}

.category-icon {
  width: 76rpx;
  height: 76rpx;
}

.category-label {
  color: #2f3944;
  font-size: 23rpx;
  font-weight: 600;
  white-space: nowrap;
}

.category-item.active .category-label {
  color: #35c66b;
  font-weight: 800;
}

/* 区块头 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 800;
}

.section-count {
  margin-left: 10rpx;
  color: #35c66b;
  font-size: 26rpx;
  font-weight: 800;
}

.section-tools {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.section-more {
  color: #8a98a8;
  font-size: 22rpx;
  font-weight: 600;
}

/* 商品网格 */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.goods-card {
  width: calc((100% - 18rpx) / 2);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  box-sizing: border-box;
}

.goods-image-wrap {
  position: relative;
  height: 230rpx;
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #ffffff 0%, #f6fbff 100%);
}

.goods-image {
  width: 100%;
  height: 100%;
  display: block;
}

.goods-status {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  font-size: 20rpx;
  line-height: 1;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.status-active {
  color: #065f46;
  background: #d1fae5;
}

.status-ended {
  color: #6b7280;
  background: #eef1f4;
}

.status-cancelled {
  color: #9a3412;
  background: #ffedd5;
}

.goods-body {
  padding: 0 18rpx 18rpx;
}

.goods-title {
  min-height: 70rpx;
  color: #1f2933;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-body-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.goods-price {
  color: #ff5a4f;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 800;
}

.goods-actions {
  display: flex;
  gap: 12rpx;
}

.goods-edit {
  font-size: 22rpx;
  color: #1989fa;
  border: 1rpx solid #91caff;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
  line-height: 1.2;
}

.goods-delete {
  font-size: 22rpx;
  color: #e34d59;
  border: 1rpx solid #f3c0c4;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
  line-height: 1.2;
}

.goods-delete.deleting {
  color: #9ca3af;
  border-color: #e5e7eb;
}

/* 空态 / 加载 */
.empty-state {
  margin-top: 60rpx;
  text-align: center;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #4b5563;
}

.empty-tip {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.loading-tip {
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
  padding: 24rpx 0;
}
