.container {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  background-color: #f2f4f7;
  padding: 20rpx 20rpx 160rpx;
}

/* 分区卡片 */
.section-card {
  width: 100%;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx 24rpx 8rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1989fa;
  line-height: 1.2;
}

.section-sub {
  font-size: 22rpx;
  font-weight: 400;
  color: #9ca3af;
  margin-left: 8rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-col {
  flex: 1;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.req {
  color: #f5222d;
  margin-right: 4rpx;
}

.input {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fafbfc;
  color: #1f2937;
}

/* 价格输入 */
.price-input-wrap {
  display: flex;
  align-items: center;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  background-color: #fafbfc;
  padding-left: 20rpx;
  box-sizing: border-box;
}

.price-input-wrap.has-value {
  border-color: #ffa940;
  background-color: #fff7e6;
}

.price-unit {
  font-size: 32rpx;
  font-weight: 700;
  color: #fa8c16;
  margin-right: 6rpx;
}

.price-input {
  flex: 1;
  border: none;
  background-color: transparent;
  padding-left: 0;
  font-size: 34rpx;
  font-weight: 700;
  color: #fa541c;
  height: 84rpx;
  line-height: 84rpx;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  background-color: #fafbfc;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #9ca3af;
  margin: 8rpx 0 16rpx;
}

/* 选择器 */
.picker {
  width: 100%;
}

.picker-inner {
  height: 84rpx;
  line-height: 84rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1f2937;
  background-color: #fafbfc;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  color: #9ca3af;
  font-size: 24rpx;
}

/* 图片网格 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.image-tile {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f3f4f6;
}

.tile-img {
  width: 100%;
  height: 100%;
  display: block;
}

.tile-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  color: #fff;
  font-size: 34rpx;
  background-color: rgba(0, 0, 0, 0.55);
  border-bottom-left-radius: 16rpx;
}

.tile-main-badge {
  position: absolute;
  left: 0;
  bottom: 0;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(25, 137, 250, 0.9);
  border-top-right-radius: 12rpx;
}

.add-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #cbd5e1;
  background-color: #fafbfc;
}

.add-plus {
  font-size: 56rpx;
  color: #9ca3af;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

/* 折叠时间区 */
.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0;
}

.toggle-arrow {
  font-size: 24rpx;
  font-weight: 400;
  color: #1989fa;
  border-left: none;
}

.time-body {
  margin-top: 20rpx;
}

.section-hint {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 20rpx;
}

.datetime-row {
  display: flex;
  gap: 16rpx;
}

.datetime-row .picker {
  flex: 1;
}

/* 提交栏 */
.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(90deg, #1989fa, #0a6cf0);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  border: none;
}

.submit-btn.disabled {
  background: #c7ced6;
  color: #f0f2f5;
}

.submit-btn::after {
  border: none;
}

.submit-tip {
  text-align: center;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 10rpx;
}

.forbidden-submit-tip {
  color: #f5222d;
}

.input.has-forbidden,
.textarea.has-forbidden {
  border-color: #f5222d !important;
  background-color: #fff1f0 !important;
}

.forbidden-warning {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  margin-top: 12rpx;
  background-color: #fff7e6;
  border-radius: 8rpx;
  border-left: 4rpx solid #fa8c16;
}

.forbidden-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.forbidden-text {
  font-size: 24rpx;
  color: #fa8c16;
  line-height: 1.5;
}
