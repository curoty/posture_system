page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.page-scroll {
  height: 100vh;
  width: 100%;
}

.container {
  padding: 0;
  padding-bottom: 120rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.intro-card {
  background-color: #ffffff;
  border-radius: 0;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
}

.intro-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.intro-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.form-card {
  background-color: #ffffff;
  border-radius: 0;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.form-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.label-required {
  font-size: 26rpx;
  color: #ff4d4f;
  margin-left: 6rpx;
}

.upload-area {
  width: 100%;
  height: 280rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.upload-area:active {
  border-color: #35c66b;
  background-color: #eafbf2;
}

.upload-area.add-btn {
  height: 160rpx;
}

.upload-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #999999;
}

.certificates-area {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.certificate-item {
  width: calc(33.333% - 12rpx);
  height: 180rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #f0f0f0;
}

.certificate-image {
  width: 100%;
  height: 100%;
}

.certificate-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-text {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1;
}

.submit-area {
  padding: 0 24rpx;
  padding-bottom: 32rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background-color: #35c66b;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(53, 198, 107, 0.3);
  margin: 0 auto;
}

.submit-btn:active {
  background-color: #20c76a;
}

.submit-btn.disabled {
  background-color: #d9d9d9;
  box-shadow: none;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}
