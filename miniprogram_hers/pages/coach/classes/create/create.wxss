.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 28rpx;
  box-sizing: border-box;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.required {
  color: #f45b5b;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e8eef4;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  background: #fafbfc;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e8eef4;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  background: #fafbfc;
}

.submit-area {
  margin-top: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #35c66b, #2db458);
  color: #fff;
  border-radius: 16rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  padding: 0;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
