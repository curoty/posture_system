.container {
  padding: 20rpx 24rpx 0;
  background: linear-gradient(180deg, #eaf9ff 0%, #f7fcff 220rpx, #f7fafc 100%);
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.forum-top-fixed {
  flex: 0 0 auto;
  margin-top: 0;
}

.post-scroll {
  flex: 1;
  min-height: 0;
}

.forum-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-bottom: 12rpx;
  min-height: 56rpx;
}

.forum-notice {
  background-color: #ffffff;
  border: 1rpx solid #eef3f7;
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.forum-notice-text {
  font-size: 20rpx;
  color: #64748b;
  display: block;
  width: 100%;
  text-align: center;
}

.header-section {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
  align-items: center;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
}

.module-tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.module-tab {
  min-width: 108rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 24rpx;
  color: #475569;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.module-tab.active {
  color: #fff;
  background: #35c66b;
}

.search-input {
  flex: 1;
  padding: 0 20rpx;
  background-color: #f9fcff;
  border-radius: 999rpx;
  font-size: 24rpx;
  border: 1rpx solid #eef3f7;
  box-sizing: border-box;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  min-width: 120rpx;
}

.notify-bell-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #eafbf2;
  border: 1rpx solid #b8ebcb;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  position: relative;
  flex: 0 0 56rpx;
}

.notify-bell-icon {
  font-size: 28rpx;
  line-height: 1;
}

.notify-bell-badge {
  position: absolute;
  top: -2rpx;
  right: -6rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background-color: #ef4444;
  color: #fff;
  border-radius: 16rpx;
  font-size: 18rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.add-btn {
  padding: 0 12rpx;
  background-color: #35c66b;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 52rpx;
  min-width: 176rpx;
  line-height: 52rpx;
  text-align: center;
  white-space: nowrap;
  flex: 0 0 176rpx;
}

.video-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  padding-bottom: 20rpx;
}

.video-item {
  background-color: #fff;
  border-radius: 22rpx;
  padding: 14rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
  display: flex;
  flex-direction: column;
}

.video-player {
  width: 100%;
  height: 220rpx;
  border-radius: 18rpx;
  background-color: #000;
}

.video-failed {
  width: 100%;
  height: 220rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e5e7eb;
  color: #6b7280;
  font-size: 24rpx;
}

.video-meta {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.video-title {
  font-size: 24rpx;
  color: #1f2933;
  font-weight: 800;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.video-author {
  font-size: 18rpx;
  color: #64748b;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.video-author-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.author-role-tag {
  flex-shrink: 0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 16rpx;
  line-height: 1.3;
  font-weight: 600;
}

.author-role-tag.coach {
  color: #ffffff;
  background-color: #52c41a;
}

.video-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 10rpx;
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  min-width: 0;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  padding: 0;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.action-detail {
  background: #eaf4ff;
  color: #49bdf5;
  border: 2rpx solid #d6eaff;
}

.action-delete {
  background: #fff3f2;
  color: #f45b5b;
  border: 2rpx solid #ffd7d4;
}

.action-moderate {
  background: #fff1f2;
  color: #b42318;
  border: 2rpx solid #fecaca;
}

.action-btn[disabled] {
  opacity: 0.5;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 20rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
}

.tabbar-spacer {
  height: 160rpx;
}
