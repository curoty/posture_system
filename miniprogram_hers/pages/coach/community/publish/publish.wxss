.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

.form-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.mode-tip {
  margin-bottom: 18rpx;
  padding: 12rpx 16rpx;
  border-radius: 10rpx;
  background-color: #e0f2fe;
  color: #075985;
  font-size: 22rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.input {
  height: 76rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 10rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  background-color: #fff;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 10rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  background-color: #fff;
}

.count {
  display: block;
  text-align: right;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.media-item {
  margin-top: 6rpx;
}

.media-actions {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
}

.media-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  text-align: center;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 24rpx;
  color: #1989fa;
  border-radius: 10rpx;
  background-color: #e8f3ff;
  border: 1rpx solid #bfdbfe;
}

.image-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.image-item {
  position: relative;
  height: 180rpx;
  border-radius: 10rpx;
  overflow: hidden;
  background-color: #f3f4f6;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.remove-icon {
  position: absolute;
  right: 6rpx;
  top: 6rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 26rpx;
}

.video-wrap {
  margin-top: 16rpx;
}

.video-preview-container {
  position: relative;
  width: 100%;
  padding-bottom: 56.25%;
  border-radius: 12rpx;
  background-color: #000;
  border: 1rpx solid #e5e7eb;
  overflow: hidden;
}

.video-preview {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.video-file-fallback {
  min-height: 220rpx;
  border-radius: 12rpx;
  border: 1rpx dashed #93c5fd;
  background-color: #eff6ff;
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.video-file-title {
  font-size: 26rpx;
  color: #1e3a8a;
  font-weight: 600;
}

.video-file-name {
  font-size: 22rpx;
  color: #1d4ed8;
  word-break: break-all;
}

.video-file-tip {
  font-size: 22rpx;
  color: #475569;
}

.video-preview-actions {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.change-video-btn,
.preview-video-btn,
.remove-video-btn {
  margin-top: 0;
  flex: 1;
  min-width: 180rpx;
  height: 64rpx;
  line-height: 1;
  font-size: 24rpx;
  border-radius: 10rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  text-align: center;
}

.change-video-btn {
  color: #1989fa;
  background-color: #e8f3ff;
  border: 1rpx solid #bfdbfe;
}

.preview-video-btn {
  color: #2563eb;
  background-color: #dbeafe;
  border: 1rpx solid #bfdbfe;
}

.remove-video-btn {
  color: #ef4444;
  background-color: #fee2e2;
  border: 1rpx solid #fecaca;
}

.change-video-btn::after,
.preview-video-btn::after,
.remove-video-btn::after {
  border: none;
}

.submit-btn {
  margin-top: 28rpx;
  border-radius: 12rpx;
  background-color: #1989fa;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}
