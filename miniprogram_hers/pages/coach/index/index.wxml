<view class="page">
  <scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="container">
      <view class="hero-header">
        <view class="hero-copy">
          <text class="greeting">你好，{{coachInfo.name || '教练'}}</text>
          <view class="hero-title-row">
          <text class="hero-title-ai">AI上轮滑</text>
          <text class="hero-title-side">{{isAdmin ? '管理端' : '教练端'}}</text>
        </view>
        </view>
        <view class="header-actions">
          <view class="notify-button" bindtap="goToNotificationCenter">
            <image class="notify-icon" src="/images/icons/bell-outline.svg" mode="aspectFit" />
            <text wx:if="{{unreadNotificationCount > 0}}" class="notify-badge">{{unreadNotificationCount > 99 ? '99+' : unreadNotificationCount}}</text>
          </view>
        </view>
      </view>

      <view class="banner-card">
        <view class="banner-copy">
          <text class="banner-title">{{isAdmin ? '今日管理安排' : '今日授课安排'}}</text>
          <text class="banner-subtitle">{{isAdmin ? '高效管理，轻松运营' : '高效带课，轻松管理'}}</text>
          <view class="banner-button" bindtap="goToScheduleOverview">{{isAdmin ? '查看数据' : '查看安排'}}</view>
        </view>
        <view class="banner-visual">
          <view class="banner-ring banner-ring-lg"></view>
          <view class="banner-ring banner-ring-sm"></view>
          <image class="banner-figure" src="/images/login-skating-child.png" mode="aspectFill" />
        </view>
      </view>

      <view class="stats-grid">
        <view class="metric-card" bindtap="goToStudentsList">
          <text class="metric-value">{{stats.studentCount || 0}}</text>
          <text class="metric-unit">人</text>
          <text class="metric-label">我的学员</text>
        </view>
        <view class="metric-card" bindtap="goToCourseList">
          <text class="metric-value">{{stats.todayCourseCount || 0}}</text>
          <text class="metric-unit">节</text>
          <text class="metric-label">今日课程</text>
        </view>
        <view class="metric-card" bindtap="goToNotificationCenter">
          <text class="metric-value">{{stats.notificationCount || 0}}</text>
          <text class="metric-unit">条</text>
          <text class="metric-label">消息通知</text>
        </view>
      </view>

      <view class="section-card">
        <view class="section-head">
          <text class="section-title">功能入口</text>
        </view>
        <view class="feature-grid">
          <view class="feature-card" bindtap="goToScheduleBooking">
            <view class="feature-icon feature-green">
              <image src="/images/icons/home-calendar.svg" mode="aspectFit" />
            </view>
            <text class="feature-text">课程预约</text>
          </view>
          <view class="feature-card" bindtap="goToSchedulePublish">
            <view class="feature-icon feature-blue">
              <image src="/images/icons/business-active.png" mode="aspectFit" />
            </view>
            <text class="feature-text">课时发布</text>
          </view>
          <view class="feature-card" bindtap="goToReportList">
            <view class="feature-icon feature-orange">
              <image src="/images/icons/notification-report.svg" mode="aspectFit" />
            </view>
            <text class="feature-text">训练报告</text>
          </view>
          <view class="feature-card" bindtap="onTapSensorDebug">
            <view class="feature-icon feature-purple">
              <image src="/images/icons/profile-course.svg" mode="aspectFit" />
            </view>
            <text class="feature-text">传感器调试</text>
          </view>
          <view class="feature-card" bindtap="goToInvitation">
            <view class="feature-icon feature-teal">
              <image src="/images/icons/bell-outline.svg" mode="aspectFit" />
            </view>
            <text class="feature-text">班级邀请</text>
          </view>
          <view class="feature-card" bindtap="goToClassManagement">
            <view class="feature-icon feature-teal">
              <image src="/images/icons/home-calendar.svg" mode="aspectFit" />
            </view>
            <text class="feature-text">班级管理</text>
          </view>
          <view wx:if="{{isAdmin || canManageAdminAccess}}" class="feature-card" bindtap="goToUserManagement">
            <view class="feature-icon feature-dark">
              <image src="/images/icons/usercenter.png" mode="aspectFit" />
            </view>
            <text class="feature-text">用户管理</text>
          </view>
        </view>
      </view>

      <view class="section-card schedule-card">
        <view class="section-head" bindtap="goToScheduleOverview">
          <text class="section-title">近期课表</text>
          <text class="section-more">查看更多 ></text>
        </view>
        <view wx:if="{{recentSchedules.length > 0}}" class="schedule-list">
          <view wx:for="{{recentSchedules}}" wx:key="id" class="schedule-item">
            <view class="schedule-time-block">
              <text class="schedule-date">{{item.monthDay}}</text>
              <text class="schedule-weekday">{{item.weekday}}</text>
            </view>
            <view class="schedule-content">
              <text class="schedule-name">{{item.title}}</text>
              <text class="schedule-meta">{{item.scheduleTime}} · {{item.venue}}</text>
            </view>
            <text class="schedule-status status-{{item.statusClass}}">{{item.statusText}}</text>
          </view>
        </view>
        <view wx:else class="empty-block">
          <text class="empty-text">暂时还没有近期课表</text>
        </view>
      </view>

      <view wx:if="{{loadError}}" class="error-banner">
        <text class="error-banner-text">{{loadError}}</text>
        <button class="retry-btn" bindtap="loadAllData" loading="{{loading}}" disabled="{{loading}}">重新加载</button>
      </view>

      <view class="section-card smart-coach-card">
        <view class="section-head">
          <text class="section-title">智能教练</text>
        </view>
        <view class="smart-coach-content">
          <view class="ble-status">
            <view class="ble-dot {{ deviceConnected ? 'connected' : '' }}"></view>
            <text class="ble-text">{{ deviceConnected ? (transportMode === 'wifi' ? 'WiFi已连接' : '蓝牙已连接') : (transportMode === 'wifi' ? 'WiFi未连接' : '蓝牙未连接') }}</text>
            <view class="transport-switch" bindtap="onToggleTransport">
              <text class="transport-switch-text">{{ transportMode === 'wifi' ? 'WiFi' : '蓝牙' }}</text>
            </view>
          </view>
          <view class="action-btn-group">
            <view class="action-btn {{ analyzing ? 'active' : '' }}" bindtap="onSmartCoachAction">
              <text class="action-btn-text">{{ analyzing ? '停止分析' : '开始分析' }}</text>
            </view>
            <view class="action-btn secondary" bindtap="onSmartCoachVoice" wx:if="{{latestAnalyzeScore > 0}}">
              <text class="action-btn-text">语音播报</text>
            </view>
          </view>
          <view class="result-area" wx:if="{{latestAnalyzeScore > 0}}">
            <view class="score-display">
              <text class="score-value">{{latestAnalyzeScore}}</text>
              <text class="score-unit">分</text>
            </view>
            <text class="level-text">等级：{{latestAnalyzeLevel}}</text>
            <text class="tip-text">{{weightShiftTip}}</text>
          </view>
        </view>
      </view>

    </view>
  </scroll-view>
  <coach-tab-bar selected="home" />
</view>
