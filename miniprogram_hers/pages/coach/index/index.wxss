page {
  height: 100%;
  background: linear-gradient(180deg, #eaf9ff 0%, #f7fcff 220rpx, #f7fafc 100%);
}

.page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #eaf9ff 0%, #f7fcff 220rpx, #f7fafc 100%);
}

.page-scroll {
  width: 100%;
  height: 100vh;
}

.container {
  width: 100%;
  padding: 20rpx 24rpx 180rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.hero-header {
  width: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 0;
  margin: 0 0 22rpx;
  box-sizing: border-box;
}

.hero-copy {
  min-width: 0;
}

.greeting {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.hero-title-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
}

.hero-title-ai,
.hero-title-side {
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 800;
}

.hero-title-ai {
  color: #35c66b;
}

.hero-title-side {
  color: #1f2933;
}

.header-actions {
  flex-shrink: 0;
}

.notify-button {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, 0.06);
}

.notify-icon {
  width: 36rpx;
  height: 36rpx;
}

.notify-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 20rpx;
  background: #ff5a4f;
  color: #fff;
  font-size: 18rpx;
  line-height: 34rpx;
  text-align: center;
  box-sizing: border-box;
}

.banner-card {
  width: 100%;
  min-height: 200rpx;
  border-radius: 22rpx;
  padding: 24rpx 8rpx 24rpx 28rpx;
  background: linear-gradient(135deg, #20c76a 0%, #0fbf61 100%);
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 2rpx;
  box-sizing: border-box;
  box-shadow: 0 14rpx 30rpx rgba(53, 198, 107, 0.22);
}

.banner-copy {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  width: 310rpx;
  flex: 0 0 310rpx;
  min-width: 0;
  margin-right: 0;
}

.banner-title {
  font-size: 38rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 800;
}

.banner-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.9);
}

.banner-button {
  margin-top: 18rpx;
  min-width: 150rpx;
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.banner-visual {
  position: relative;
  width: 286rpx;
  height: 176rpx;
  flex-shrink: 0;
  margin-left: 4rpx;
  border-radius: 36rpx;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
  background: transparent;
  box-shadow: none;
}

.banner-ring {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
}

.banner-ring-lg {
  width: 150rpx;
  height: 150rpx;
  right: -54rpx;
  top: -42rpx;
}

.banner-ring-sm {
  width: 82rpx;
  height: 82rpx;
  left: -24rpx;
  bottom: -18rpx;
}

.banner-figure {
  position: absolute;
  left: 0;
  top: 0;
  width: 286rpx;
  height: 176rpx;
  border-radius: 36rpx;
  opacity: 0.92;
  -webkit-mask-image: radial-gradient(ellipse at center, #000 52%, rgba(0, 0, 0, 0.72) 70%, transparent 100%);
  mask-image: radial-gradient(ellipse at center, #000 52%, rgba(0, 0, 0, 0.72) 70%, transparent 100%);
  box-shadow: none;
}

.stats-grid {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.metric-card {
  min-height: 136rpx;
  background: #ffffff;
  border-radius: 18rpx;
  padding: 18rpx 8rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
}

.metric-value {
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #35c66b;
}

.metric-value.warm {
  color: #f59e0b;
}

.metric-unit {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #35c66b;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #64748b;
  text-align: center;
}

.section-card {
  width: 100%;
  margin-top: 16rpx;
  padding: 24rpx 18rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #1f2933;
}

.section-more {
  font-size: 22rpx;
  color: #8a98a8;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.feature-card {
  min-height: 136rpx;
  border-radius: 16rpx;
  background: #f9fcff;
  border: 1rpx solid #eef3f7;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.feature-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-icon image {
  width: 38rpx;
  height: 38rpx;
}

.feature-green {
  background: #eafbf2;
}

.feature-blue {
  background: #eaf6ff;
}

.feature-orange {
  background: #fff4e8;
}

.feature-purple {
  background: #f1edff;
}

.feature-teal {
  background: #e0f7fa;
}

.feature-dark {
  background: #e8ecf0;
}

.feature-text {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #1f2933;
  font-weight: 600;
}

.schedule-card {
  margin-bottom: 10rpx;
}

.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.schedule-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef3f7;
}

.schedule-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.schedule-time-block {
  width: 92rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-start;
}

.schedule-date {
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #35c66b;
}

.schedule-weekday {
  font-size: 20rpx;
  color: #8a98a8;
}

.schedule-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.schedule-name {
  font-size: 28rpx;
  line-height: 1.35;
  color: #1f2933;
  font-weight: 700;
}

.schedule-meta {
  font-size: 22rpx;
  line-height: 1.5;
  color: #8a98a8;
}

.schedule-status {
  flex-shrink: 0;
  min-width: 108rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.schedule-status.status-pending {
  background: #eafbf2;
  color: #35c66b;
}

.schedule-status.status-active {
  background: #eaf6ff;
  color: #49bdf5;
}

.schedule-status.status-completed {
  background: #f2f4f7;
  color: #8a98a8;
}

.empty-block {
  padding: 34rpx 0 12rpx;
  text-align: center;
}

.empty-text {
  font-size: 24rpx;
  color: #8a98a8;
}

.error-banner {
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #fff6f6;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  align-items: center;
}

.error-banner-text {
  color: #ef4444;
  font-size: 22rpx;
}

.retry-btn {
  width: 180rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 12rpx;
  background: #35c66b;
  color: #ffffff;
  font-size: 24rpx;
  padding: 0;
  text-align: center;
}

.smart-coach-card {
  margin-top: 16rpx;
}

.smart-coach-content {
  padding-top: 10rpx;
}

.ble-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  justify-content: space-between;
}

.ble-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ef4444;
}

.ble-dot.connected {
  background: #35c66b;
}

.ble-text {
  font-size: 24rpx;
  color: #64748b;
  flex: 1;
}

.transport-switch {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  border-radius: 20rpx;
}

.transport-switch-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

.action-btn-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #35c66b 0%, #20c76a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(53, 198, 107, 0.3);
}

.action-btn.secondary {
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.3);
}

.action-btn.active {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  box-shadow: 0 8rpx 20rpx rgba(245, 158, 11, 0.3);
}

.action-btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.result-area {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f9fcff;
  border: 1rpx solid #eef3f7;
}

.score-display {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.score-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #35c66b;
}

.score-unit {
  font-size: 28rpx;
  color: #64748b;
}

.level-text {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #1f2933;
}

.tip-text {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}
