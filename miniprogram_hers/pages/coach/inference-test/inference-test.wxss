.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f7fa;
}

.status-bar {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.status-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.status-item:last-child {
  margin-bottom: 0;
}

.status-item .label {
  color: #666;
  width: 100rpx;
}

.status-item .value {
  color: #333;
  font-weight: 500;
  flex: 1;
}

.status-disconnected {
  color: #999 !important;
}

.status-connecting {
  color: #ff9500 !important;
}

.status-connected {
  color: #07c160 !important;
}

.frame-count {
  color: #1989fa !important;
  font-size: 36rpx;
  font-weight: 600;
}

.btn-group {
  margin-bottom: 24rpx;
}

.btn {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 20rpx 0;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: white;
}

.btn.secondary {
  background: white;
  color: #1989fa;
  border: 2rpx solid #1989fa;
}

.btn.success {
  background: #07c160;
  color: white;
}

.btn.danger {
  background: #fa5151;
  color: white;
}

.btn.warn {
  background: #ff9500;
  color: white;
}

.btn.disabled-success,
.btn.disabled-warn {
  background: #e5e5e5 !important;
  color: #999 !important;
  border: none;
}

.btn[disabled] {
  opacity: 1;
}

.logs-container {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.logs-title {
  background: #f7f8fa;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #eee;
}

.logs-content {
  height: 520rpx;
  padding: 20rpx 24rpx;
}

.log-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 10rpx;
  font-family: 'Courier New', monospace;
  word-break: break-all;
}

.log-item.latest {
  color: #1989fa;
}

.help-text {
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
  white-space: pre-wrap;
}

.result-card {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  color: white;
}

.result-title {
  font-size: 28rpx;
  opacity: 0.9;
  text-align: center;
  margin-bottom: 20rpx;
}

.score-row {
  display: flex;
  justify-content: center;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.score-number {
  font-size: 80rpx;
  font-weight: 700;
  line-height: 1;
}

.score-label {
  font-size: 28rpx;
  margin-left: 10rpx;
  opacity: 0.85;
}

.comment-area {
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255,255,255,0.95);
}
