.container {
  padding: 16rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.header-section {
  display: flex;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: 1rpx solid #ddd;
}

.status-picker {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #ddd;
  min-width: 150rpx;
}

.picker-text {
  font-size: 24rpx;
  color: #333;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-id {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.status-pending {
  background-color: #fff3cd;
  color: #ff9500;
}

.status-completed {
  background-color: #e8f5e9;
  color: #07C160;
}

.status-cancelled {
  background-color: #f8d7da;
  color: #ff3b30;
}

.order-info {
  margin-bottom: 15rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.order-course {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.order-student {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.order-time {
  font-size: 20rpx;
  color: #999;
  display: block;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff3b30;
}

.order-actions {
  display: flex;
  gap: 10rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  background-color: #f0f0f0;
  color: #333;
  border: none;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.action-btn.danger {
  background-color: #ff3b30;
  color: #fff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 20rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
}
