.container {
  min-height: 100vh;
  padding: 24rpx;
  background: #f5f7fb;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(17, 40, 80, 0.06);
}

.add-card {
  margin-bottom: 18rpx;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.desc {
  display: block;
  margin-top: 10rpx;
  color: #5f6c80;
  font-size: 24rpx;
}

.input {
  margin-top: 18rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: #f5f8ff;
  border: 1rpx solid #dce6ff;
  padding: 0 18rpx;
  font-size: 28rpx;
  color: #2f3b52;
  box-sizing: border-box;
}

.picker-row {
  margin-top: 14rpx;
  min-height: 72rpx;
  border-radius: 12rpx;
  border: 1rpx solid #dce6ff;
  background: #f8fbff;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-label {
  font-size: 26rpx;
  color: #55657f;
}

.picker-value {
  font-size: 28rpx;
  color: #1f2d3d;
  font-weight: 600;
}

.submit-btn {
  margin-top: 18rpx;
  height: 78rpx;
  border-radius: 14rpx;
  background: #2185ff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.submit-message {
  margin-top: 12rpx;
  display: block;
  font-size: 24rpx;
  color: #0f8f54;
}

.error-tip {
  margin-top: 18rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #fff3f2;
  color: #d14343;
  font-size: 26rpx;
}

.list-wrap {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 6rpx 20rpx rgba(17, 40, 80, 0.05);
}

.user-main {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-name {
  max-width: 360rpx;
  font-size: 30rpx;
  color: #1f2d3d;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 86rpx;
  padding: 0 12rpx;
  height: 36rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.role-admin {
  background: #fef4d8;
  color: #8a6402;
}

.role-coach {
  background: #e9f7ef;
  color: #0f7a41;
}

.level-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  height: 34rpx;
  border-radius: 18rpx;
  font-size: 21rpx;
  color: #0c6f8f;
  background: #e9f8ff;
}

.phone {
  display: block;
  margin-top: 10rpx;
  color: #4f5f7b;
  font-size: 25rpx;
}

.hint {
  display: block;
  margin-top: 8rpx;
  color: #7a869a;
  font-size: 23rpx;
}

.access-switch {
  flex-shrink: 0;
}

.empty,
.loading {
  margin-top: 26rpx;
  text-align: center;
  color: #7a869a;
  font-size: 26rpx;
}
