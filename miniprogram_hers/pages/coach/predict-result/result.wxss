.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f2749 0%, #123363 40%, #f5f7fb 40%);
  padding-bottom: 160rpx;
}

.score-hero {
  display: flex;
  justify-content: center;
  padding: 60rpx 0 40rpx;
}

.score-ring {
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 0 60rpx rgba(96,165,250,0.3);
}

.score-ring.excellent {
  border-color: rgba(52, 211, 153, 0.6);
  box-shadow: 0 0 60rpx rgba(52, 211, 153, 0.35);
  background: radial-gradient(circle, rgba(52, 211, 153, 0.2) 0%, rgba(15, 39, 73, 0.6) 100%);
}

.score-ring.good {
  border-color: rgba(96, 165, 250, 0.6);
  box-shadow: 0 0 60rpx rgba(96, 165, 250, 0.35);
  background: radial-gradient(circle, rgba(96, 165, 250, 0.2) 0%, rgba(15, 39, 73, 0.6) 100%);
}

.score-ring.mid {
  border-color: rgba(251, 191, 36, 0.6);
  box-shadow: 0 0 60rpx rgba(251, 191, 36, 0.35);
  background: radial-gradient(circle, rgba(251, 191, 36, 0.2) 0%, rgba(15, 39, 73, 0.6) 100%);
}

.score-ring.fail {
  border-color: rgba(248, 113, 113, 0.6);
  box-shadow: 0 0 60rpx rgba(248, 113, 113, 0.35);
  background: radial-gradient(circle, rgba(248, 113, 113, 0.2) 0%, rgba(15, 39, 73, 0.6) 100%);
}

.score-value {
  font-size: 64rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}

.score-ring.excellent .score-value { color: #6ee7b7; }
.score-ring.good .score-value { color: #93c5fd; }
.score-ring.mid .score-value { color: #fcd34d; }
.score-ring.fail .score-value { color: #fca5a5; }

.score-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

.result-card {
  margin: 0 32rpx 20rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.result-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}

.row-label {
  font-size: 28rpx;
  color: #475569;
  font-weight: 600;
}

.row-value {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 700;
}

.quality-badge {
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
}

.quality-badge.excellent {
  background: #ecfdf5;
}
.quality-badge.excellent .quality-text { color: #059669; }
.quality-badge.good {
  background: #eff6ff;
}
.quality-badge.good .quality-text { color: #2563eb; }
.quality-badge.mid {
  background: #fffbeb;
}
.quality-badge.mid .quality-text { color: #d97706; }
.quality-badge.fail {
  background: #fef2f2;
}
.quality-badge.fail .quality-text { color: #dc2626; }

.quality-text {
  font-size: 26rpx;
  font-weight: 700;
}

.divider {
  height: 1rpx;
  background: #e2e8f0;
}

.comment-card {
  margin: 0 32rpx 20rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.voice-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
}

.voice-btn.voice-playing {
  background: #fef2f2;
  border-color: #fecaca;
}

.voice-icon {
  font-size: 26rpx;
}

.voice-text {
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 600;
}

.voice-playing .voice-text {
  color: #dc2626;
}

.comment-text {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.8;
}

.detail-card {
  margin: 0 32rpx 20rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.detail-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
  display: block;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-node {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  min-width: 120rpx;
}

.detail-score {
  font-size: 24rpx;
  color: #6366f1;
  font-weight: 700;
  min-width: 100rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #64748b;
  flex: 1;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.04);
  z-index: 100;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  padding: 0;
}

.back-btn {
  background: #f1f5f9;
  color: #475569;
}

.save-btn {
  background: linear-gradient(135deg, #35c66b 0%, #2db85f 100%);
  color: #ffffff;
}
