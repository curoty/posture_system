page {
  height: 100%;
  background: linear-gradient(180deg, #eaf9ff 0%, #f7fcff 220rpx, #f7fafc 100%);
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eaf9ff 0%, #f7fcff 220rpx, #f7fafc 100%);
}

.page-scroll {
  height: 100vh;
}

.container {
  width: 100%;
  padding: 20rpx 24rpx 180rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.hero-panel {
  margin-top: 12rpx;
  height: 230rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #20c76a 0%, #0fbf61 100%);
  padding: 28rpx 24rpx 72rpx;
  box-sizing: border-box;
  box-shadow: 0 14rpx 30rpx rgba(53, 198, 107, 0.18);
  width: 100%;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 0 8rpx;
}

.avatar-shell {
  width: 132rpx;
  height: 132rpx;
  border-radius: 66rpx;
  padding: 6rpx;
  background: rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding-top: 10rpx;
}

.hero-name {
  display: block;
  font-size: 38rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 800;
}

.hero-tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.hero-role,
.hero-level {
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
}

.hero-role {
  color: #35c66b;
  background: rgba(255, 255, 255, 0.72);
}

.hero-level {
  color: #8a5b00;
  background: #ffe59c;
}

.hero-org {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.hero-setting {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-setting image {
  width: 34rpx;
  height: 34rpx;
}

.stats-card {
  margin-top: -44rpx;
  background: #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
  padding: 18rpx 10rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
}

.stat-item {
  min-height: 116rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-value {
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #35c66b;
}

.stat-label {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #8a98a8;
}

.info-card,
.action-card {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
  overflow: hidden;
}

.info-row,
.action-row {
  min-height: 108rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eef0f3;
  box-sizing: border-box;
}

.info-card .info-row:last-child,
.action-card .action-row:last-child {
  border-bottom: none;
}

.info-left,
.info-right {
  display: flex;
  align-items: center;
}

.info-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 14rpx;
}

.info-label {
  font-size: 26rpx;
  color: #606b78;
}

.info-value {
  font-size: 24rpx;
  color: #7b8490;
  text-align: right;
}

.accent {
  color: #35c66b;
}

.chevron {
  width: 26rpx;
  height: 26rpx;
  margin-left: 10rpx;
}

.action-text {
  color: #1f2933;
}

.logout-text {
  color: #f45b5b;
}

.logout-row .info-icon {
  opacity: 0.95;
}

.org-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.org-modal {
  width: 600rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.org-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.org-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.org-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-text {
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
}

.org-modal-body {
  max-height: 560rpx;
  padding: 12rpx 0;
}

.org-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
}

.org-item-check {
  margin-right: 20rpx;
}

.check-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-circle.checked {
  background: #35c66b;
  border-color: #35c66b;
}

.check-mark {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
}

.org-item-name {
  font-size: 28rpx;
  color: #333333;
}

.org-item.selected .org-item-name {
  color: #35c66b;
}

.org-modal-footer {
  display: flex;
  border-top: 1rpx solid #f5f5f5;
}

.org-modal-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 0;
  border: none;
  margin: 0;
  padding: 0;
}

.org-modal-btn.cancel {
  color: #666666;
  background: #f7fafc;
  border-right: 1rpx solid #f5f5f5;
}

.org-modal-btn.confirm {
  color: #ffffff;
  background: #35c66b;
}
