.page { padding: 24rpx; min-height: 100vh; background: #f5f6fa; }
.card { background: #fff; border-radius: 16rpx; padding: 32rpx; text-align: center; }
.title { font-size: 36rpx; font-weight: 600; color: #222; margin-bottom: 12rpx; }
.desc { font-size: 26rpx; color: #888; margin-bottom: 32rpx; }
.loading-box { padding: 60rpx 0; display: flex; flex-direction: column; align-items: center; gap: 16rpx; color: #999; font-size: 26rpx; }
.loading-spinner { width: 48rpx; height: 48rpx; border: 4rpx solid #e8e8e8; border-top-color: #35C66B; border-radius: 50%; animation: spin 800ms linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.qr-image { width: 430rpx; height: 430rpx; margin: 24rpx auto; display: block; border: 2rpx solid #eee; border-radius: 12rpx; }
.invite-code-box { margin: 12rpx 0 8rpx; padding: 24rpx; border-radius: 20rpx; background: #f7fbf8; }
.invite-code-label { display: block; font-size: 24rpx; color: #6a7b70; }
.invite-code-value { display: block; margin-top: 10rpx; font-size: 52rpx; letter-spacing: 10rpx; font-weight: 700; color: #1f7a45; }
.btn { margin-top: 24rpx; width: 100%; height: 80rpx; line-height: 80rpx; border-radius: 40rpx; font-size: 30rpx; }
.btn.primary { background: #35C66B; color: #fff; }
.btn.secondary { background: #f0f0f0; color: #555; }
.error { color: #e74c3c; margin-bottom: 24rpx; font-size: 28rpx; }
