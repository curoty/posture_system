.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx;
  background-color: #f5f5f5;
}

.report-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}

.report-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 14rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #6b7280;
}

.coach-line {
  margin-bottom: 16rpx;
}

.coach-label,
.coach-name {
  font-size: 24rpx;
  color: #374151;
}

.coach-name {
  font-weight: 600;
}

.flower-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff8fb;
  border: 1rpx solid #ffd6e8;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 14rpx;
}

.flower-summary-label {
  font-size: 24rpx;
  color: #9f1239;
}

.flower-summary-value {
  font-size: 28rpx;
  color: #be185d;
  font-weight: 700;
}

.flower-list {
  background: #fff;
  border: 1rpx solid #fce7f3;
  border-radius: 12rpx;
  padding: 14rpx;
  margin-bottom: 16rpx;
}

.flower-list-title {
  display: block;
  font-size: 24rpx;
  color: #9f1239;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.flower-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #fdf2f8;
}

.flower-item:last-child {
  border-bottom: none;
}

.flower-student {
  font-size: 24rpx;
  color: #1f2937;
}

.flower-count {
  font-size: 24rpx;
  color: #be185d;
  font-weight: 600;
}

.content-box {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 18rpx;
}

.content-title {
  display: block;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.content-text {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.7;
  white-space: pre-wrap;
}

.state-tip {
  text-align: center;
  padding: 36rpx 0;
  font-size: 24rpx;
  color: #9ca3af;
}

.state-tip.error {
  color: #ef4444;
}
