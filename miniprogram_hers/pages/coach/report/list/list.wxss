.container {
  display: block;
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx 24rpx 160rpx;
  background: linear-gradient(180deg, #eaf9ff 0%, #f7fcff 220rpx, #f7fafc 100%);
}

.publish-card {
  width: 100%;
  background: #ffffff;
  border-radius: 22rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
  margin-bottom: 20rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  color: #1f2933;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.title-input {
  width: 100%;
  box-sizing: border-box;
  min-height: 72rpx;
  border: 1rpx solid #eef3f7;
  border-radius: 18rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
  background: #f9fcff;
  margin-bottom: 14rpx;
}

.content-input {
  width: 100%;
  height: 220rpx;
  box-sizing: border-box;
  border: 1rpx solid #eef3f7;
  border-radius: 18rpx;
  padding: 14rpx 18rpx;
  font-size: 26rpx;
  background: #f9fcff;
  margin-bottom: 16rpx;
}

.flower-section {
  background: #f9fcff;
  border: 1rpx solid #eef3f7;
  border-radius: 18rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.flower-title-row {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
  margin-bottom: 10rpx;
}

.flower-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2933;
  line-height: 1.4;
  word-break: break-all;
}

.flower-tip {
  font-size: 22rpx;
  color: #8a98a8;
  line-height: 1.4;
}

.flower-state {
  font-size: 22rpx;
  color: #6b7280;
  padding: 8rpx 0;
}

.flower-state.error {
  color: #dc2626;
}

.flower-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.flower-item {
  width: 100%;
  padding-top: 8rpx;
  border-top: 1rpx solid #eef3f7;
}

.flower-item:first-child {
  border-top: none;
  padding-top: 0;
}

.student-name {
  display: block;
  font-size: 24rpx;
  color: #111827;
  line-height: 1.4;
  word-break: break-all;
}

.student-row {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.student-meta {
  font-size: 20rpx;
  color: #0f766e;
  flex-shrink: 0;
}

.student-lock {
  font-size: 20rpx;
  color: #b91c1c;
  flex-shrink: 0;
}

.flower-editor-row {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.flower-editor-row.disabled {
  opacity: 0.55;
}

.flower-step {
  flex: 1;
  max-width: 220rpx;
  min-width: 90rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #fff;
  background: #35c66b;
  text-align: center;
}

.flower-step.disabled {
  background: #b8ebcb;
}

.flower-input {
  width: 96rpx;
  min-width: 96rpx;
  height: 56rpx;
  border: 1rpx solid #b8ebcb;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  background: #fff;
  box-sizing: border-box;
}

.flower-unit {
  font-size: 24rpx;
  color: #35c66b;
  flex-shrink: 0;
}

.publish-btn {
  height: 76rpx;
  line-height: 1;
  border-radius: 999rpx;
  font-size: 28rpx;
  background: #35c66b;
  color: #fff;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  text-align: center;
}

.publish-btn[disabled] {
  opacity: 0.65;
}

.publish-btn::after {
  border: none;
}

.list-title-wrap {
  width: 100%;
  box-sizing: border-box;
  padding: 0 6rpx 10rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1f2933;
}

.report-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.report-item {
  width: 100%;
  background: #fff;
  border-radius: 22rpx;
  padding: 20rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
}

.report-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.report-title {
  flex: 1;
  font-size: 28rpx;
  color: #1f2933;
  font-weight: 800;
}

.report-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.report-preview {
  display: block;
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.report-foot {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.student-count {
  font-size: 22rpx;
  color: #6b7280;
}

.flower-count {
  font-size: 22rpx;
  color: #35c66b;
  font-weight: 600;
}

.detail-arrow {
  margin-left: auto;
  width: 100%;
  text-align: right;
  font-size: 22rpx;
  color: #35c66b;
}

.state-tip {
  text-align: center;
  padding: 36rpx 0;
  font-size: 24rpx;
  color: #9ca3af;
}

.state-tip.error {
  color: #ef4444;
}
