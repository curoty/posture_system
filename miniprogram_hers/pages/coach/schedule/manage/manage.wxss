page {
  height: 100%;
  background: linear-gradient(180deg, #eaf9ff 0%, #f7fcff 220rpx, #f7fafc 100%);
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eaf9ff 0%, #f7fcff 220rpx, #f7fafc 100%);
}

.page-scroll {
  height: 100vh;
}

.container {
  padding: 16rpx 16rpx 184rpx;
  box-sizing: border-box;
}

.hero-card {
  padding: 30rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #20c76a 0%, #0fbf61 100%);
  box-shadow: 0 14rpx 30rpx rgba(53, 198, 107, 0.18);
}

.hero-title {
  display: block;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.9);
}

.card {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.card-title {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #1f2933;
}

.card-subtitle {
  font-size: 22rpx;
  color: #8a98a8;
}

.selector-actions {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.mini-btn {
  min-width: 96rpx;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #35c66b;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.mini-btn.ghost {
  background: #edf8f1;
  color: #35c66b;
  border: 1rpx solid #b8ebcb;
}

.coach-item {
  min-height: 84rpx;
  padding: 0 18rpx;
  margin-bottom: 12rpx;
  border-radius: 18rpx;
  background: #f9fcff;
  border: 1rpx solid #eef3f7;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.coach-checkbox {
  margin-right: 12rpx;
}

.coach-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.coach-name {
  font-size: 26rpx;
  color: #1f2933;
  font-weight: 700;
}

.coach-level {
  font-size: 20rpx;
  color: #35c66b;
  background: #eafbf2;
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
}

.coach-empty,
.readonly-tip {
  padding: 28rpx 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.05);
  font-size: 24rpx;
  color: #8a98a8;
  line-height: 1.6;
}

.field-card,
.notes-card {
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #f9fcff;
  border: 1rpx solid #eef3f7;
  box-sizing: border-box;
}

.field-card {
  min-height: 96rpx;
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.field-label {
  font-size: 24rpx;
  color: #606b78;
}

.field-value {
  font-size: 26rpx;
  color: #1f2933;
  font-weight: 600;
}

.field-value.placeholder {
  color: #b0b8c4;
}

.time-row {
  display: flex;
  gap: 12rpx;
}

.time-picker {
  flex: 1;
}

.notes-card {
  margin-top: 2rpx;
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.notes-input {
  width: 100%;
  height: 180rpx;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #1f2933;
}

.submit-btn,
.weekly-btn {
  margin-top: 16rpx;
  width: 100%;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.submit-btn {
  background: #35c66b;
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(53, 198, 107, 0.2);
}

.weekly-btn {
  background: #edf8f1;
  color: #35c66b;
  border: 1rpx solid #b8ebcb;
}

.weekly-tip {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8a98a8;
}
