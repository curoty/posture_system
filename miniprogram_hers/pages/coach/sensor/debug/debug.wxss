.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 14rpx rgba(15, 23, 42, 0.05);
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.subtitle.no-margin {
  margin-bottom: 0;
}

.field {
  margin-top: 12rpx;
}

.label {
  display: block;
  font-size: 22rpx;
  color: #475569;
  margin-bottom: 6rpx;
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.node-count {
  font-size: 20rpx;
  color: #94a3b8;
}

.input {
  width: 100%;
  min-height: 72rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe5f0;
  border-radius: 10rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #1f2937;
}

.picker-value {
  width: 100%;
  min-height: 72rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe5f0;
  border-radius: 10rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #1f2937;
  display: flex;
  align-items: center;
}

.picker-value.disabled {
  color: #94a3b8;
}

.field-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #b45309;
}

.ble-block {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid #dbe5f0;
  background: #f8fbff;
}

.ble-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.ble-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #0f172a;
}

.ble-tag {
  min-height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  padding: 0 14rpx;
  font-size: 22rpx;
  border: 1rpx solid #dbe5f0;
  background: #f8fafc;
  color: #64748b;
}

.ble-tag.ok {
  background: #ecfeff;
  color: #0f766e;
  border-color: #99f6e4;
}

.ble-tag.idle {
  background: #f8fafc;
  color: #64748b;
  border-color: #dbe5f0;
}

.wifi-block {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid #dbe5f0;
  background: #f0fdf4;
}

.wifi-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.wifi-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #166534;
}

.wifi-tag {
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  border-radius: 6rpx;
  border: 1rpx solid #bbf7d0;
  background: #f0fdf4;
  color: #166534;
}

.wifi-tag.ok {
  background: #dcfce7;
  color: #15803d;
  border-color: #86efac;
}

.wifi-tag.idle {
  background: #f8fafc;
  color: #64748b;
  border-color: #dbe5f0;
}

.wifi-field {
  margin-top: 10rpx;
}

.wifi-label {
  display: block;
  font-size: 24rpx;
  color: #475569;
  margin-bottom: 6rpx;
}

.wifi-input {
  width: 100%;
  padding: 10rpx 14rpx;
  font-size: 26rpx;
  background: #ffffff;
  border: 1rpx solid #d1d5db;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.wifi-btn {
  margin-top: 12rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%) !important;
  border-color: #22c55e !important;
}

.wifi-btn::after {
  border-color: #22c55e !important;
}

.ble-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #475569;
  word-break: break-all;
}

.ble-debug {
  color: #334155;
  line-height: 1.45;
}

.ble-btn {
  margin-top: 12rpx;
  width: 100%;
  color: #ffffff !important;
  background: #2563eb !important;
}

.preset-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.preset-label {
  font-size: 22rpx;
  color: #64748b;
}

.preset-chip {
  min-width: 64rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dbe5f0;
  background: #f8fafc;
  color: #475569;
  font-size: 22rpx;
  text-align: center;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.preset-chip.active {
  border-color: #60a5fa;
  background: #e8f1ff;
  color: #1d4ed8;
  font-weight: 600;
}

.node-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 6rpx;
}

.node-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 90rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dbe5f0;
  background: #f8fafc;
  color: #475569;
  font-size: 22rpx;
  padding: 0 18rpx;
  margin: 5rpx;
  box-sizing: border-box;
}

.node-chip.active {
  border-color: #3b82f6;
  background: #dbeafe;
  color: #1d4ed8;
  font-weight: 600;
}

.textarea {
  width: 100%;
  min-height: 108rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe5f0;
  border-radius: 10rpx;
  padding: 14rpx 18rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  color: #1f2937;
}

.actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.btn {
  flex: 1;
  border-radius: 10rpx;
  font-size: 26rpx;
  line-height: 78rpx;
  height: 78rpx;
  text-align: center;
}

.primary {
  color: #ffffff !important;
  background: #1d7df2 !important;
}

.secondary {
  color: #ffffff !important;
  background: #0ea5a5 !important;
}

.hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
}

.list-link {
  margin-top: 12rpx;
  text-align: center;
  color: #2563eb;
  font-size: 24rpx;
}

.calibration-row {
  margin-top: 16rpx;
}

.calibration-btn {
  width: 100%;
  border-radius: 10rpx;
  font-size: 26rpx;
  line-height: 72rpx;
  height: 72rpx;
  text-align: center;
  color: #ffffff !important;
  background: #f59e0b !important;
}

.calibration-status {
  margin-left: 16rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.calibration-status.ok {
  color: #16a34a;
}

.error {
  font-size: 24rpx;
  color: #b91c1c;
  white-space: pre-wrap;
  word-break: break-all;
}

.ble-debug-text {
  font-size: 20rpx;
  color: #666;
  background: #f5f5f5;
  padding: 10rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  white-space: pre-wrap;
  word-break: break-all;
  max-height: 300rpx;
  overflow-y: auto;
  line-height: 1.6;
}

.tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7f1d1d;
}

.status-card {
  background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
}

.status-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.status-tag {
  height: 46rpx;
  line-height: 46rpx;
  border-radius: 999rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
  border: 1rpx solid #dbe5f0;
  color: #64748b;
  background: #f8fafc;
}

.status-tag.ok {
  background: #ecfeff;
  color: #0f766e;
  border-color: #99f6e4;
}

.status-tag.idle {
  background: #f8fafc;
  color: #64748b;
  border-color: #dbe5f0;
}

.status-tag.info {
  background: #eef2ff;
  color: #3730a3;
  border-color: #c7d2fe;
}

.status-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
}

.quick-result-card {
  border: 1rpx solid #dbeafe;
  background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
  padding: 24rpx;
}

.quick-result-card .subtitle {
  font-size: 34rpx;
}

.quick-result-row {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
}

.quick-result-item {
  flex: 1;
  border-radius: 12rpx;
  background: #eef6ff;
  border: 1rpx solid #cfe2ff;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
}

.quick-result-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #64748b;
}

.quick-result-value {
  display: block;
  margin-top: 10rpx;
  font-size: 58rpx;
  line-height: 1.05;
  font-weight: 700;
  color: #1d4ed8;
}

.quick-result-card .status-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.section-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.text-btn {
  color: #2563eb;
  font-size: 22rpx;
}

.json {
  margin-top: 8rpx;
  display: block;
  white-space: pre-wrap;
  word-break: break-all;
  font-size: 22rpx;
  line-height: 1.45;
  color: #0f172a;
}

.empty-tip {
  margin-top: 8rpx;
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
}

.intro-card .title {
  margin-bottom: 0;
}

.mode-btn {
  min-width: 136rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #eaf3ff;
  border: 1rpx solid #bfdbfe;
  color: #1d4ed8;
}

.flow-card {
  background: linear-gradient(140deg, #0f2749 0%, #123363 52%, #0d2a52 100%);
  color: #e2ecff;
  border: 1rpx solid rgba(147, 197, 253, 0.25);
  position: relative;
  overflow: hidden;
}

.flow-card.done {
  background: linear-gradient(140deg, #0f304e 0%, #0f4b68 55%, #0b3854 100%);
}

.flow-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.flow-head-left {
  flex: 1;
  min-width: 0;
}

.flow-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #f1f5ff;
}

.flow-status {
  margin-top: 8rpx;
  display: block;
  font-size: 22rpx;
  color: #c7dcff;
  line-height: 1.4;
}

.flow-progress-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.flow-progress-track {
  margin-top: 14rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.28);
  overflow: hidden;
}

.flow-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #22d3ee 0%, #60a5fa 52%, #818cf8 100%);
  animation: flow-progress-glow 1.2s ease-in-out infinite;
}

.flow-meta-row {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.flow-meta-item {
  font-size: 20rpx;
  color: #cbd9f5;
  background: rgba(148, 163, 184, 0.18);
  border: 1rpx solid rgba(191, 219, 254, 0.2);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.flow-bars {
  margin-top: 14rpx;
  height: 56rpx;
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
}

.flow-bar {
  flex: 1;
  min-width: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #22d3ee 0%, #60a5fa 100%);
  opacity: 0.85;
  animation: flow-bar-pulse 0.95s ease-in-out infinite alternate;
}

.flow-stage-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.flow-stage {
  min-height: 42rpx;
  border-radius: 999rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.35);
  background: rgba(15, 23, 42, 0.24);
}

.flow-stage-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #64748b;
  flex-shrink: 0;
}

.flow-stage-label {
  font-size: 20rpx;
  color: #cbd5e1;
}

.flow-stage-done {
  border-color: rgba(94, 234, 212, 0.45);
  background: rgba(13, 148, 136, 0.2);
}

.flow-stage-done .flow-stage-dot {
  background: #2dd4bf;
}

.flow-stage-done .flow-stage-label {
  color: #e6fffb;
}

.flow-stage-active {
  border-color: rgba(125, 211, 252, 0.65);
  background: rgba(59, 130, 246, 0.24);
}

.flow-stage-active .flow-stage-dot {
  background: #7dd3fc;
  animation: flow-dot-blink 0.75s ease-in-out infinite;
}

.flow-stage-active .flow-stage-label {
  color: #f0f9ff;
}

.flow-metric-grid {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.flow-metric-item {
  flex: 1 1 calc(50% - 6rpx);
  min-width: 220rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  background: rgba(15, 23, 42, 0.28);
  padding: 10rpx 12rpx;
}

.flow-metric-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8rpx;
}

.flow-metric-name {
  font-size: 20rpx;
  color: #cbd5e1;
}

.flow-metric-score {
  font-size: 22rpx;
  font-weight: 700;
  color: #e0ecff;
}

.flow-metric-track {
  margin-top: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.24);
  overflow: hidden;
}

.flow-metric-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #06b6d4 0%, #3b82f6 100%);
}

.number-stream {
  margin-top: 14rpx;
}

.number-stream-title {
  font-size: 20rpx;
  color: #bae6fd;
  letter-spacing: 0.8rpx;
  margin-bottom: 8rpx;
}

.number-stream-box {
  border-radius: 12rpx;
  border: 1rpx solid rgba(94, 234, 212, 0.22);
  background: linear-gradient(180deg, rgba(7, 22, 34, 0.8) 0%, rgba(3, 9, 19, 0.95) 100%);
  padding: 8rpx 12rpx;
  max-height: 240rpx;
  overflow: hidden;
}

.number-stream-line {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 6rpx 0;
  border-top: 1rpx dashed rgba(148, 163, 184, 0.2);
  animation: stream-line-in 280ms ease-out;
}

.number-stream-line:first-of-type {
  border-top: none;
}

.number-stream-time {
  flex-shrink: 0;
  min-width: 76rpx;
  font-size: 18rpx;
  color: #99f6e4;
  font-family: "Consolas", "Courier New", monospace;
}

.number-stream-text {
  flex: 1;
  min-width: 0;
  font-size: 19rpx;
  line-height: 1.35;
  color: #5eead4;
  font-family: "Consolas", "Courier New", monospace;
  word-break: break-all;
}

.number-stream-info .number-stream-time,
.number-stream-info .number-stream-text {
  color: #7dd3fc;
}

.number-stream-data .number-stream-time,
.number-stream-data .number-stream-text {
  color: #5eead4;
}

.number-stream-success .number-stream-time,
.number-stream-success .number-stream-text {
  color: #86efac;
}

.number-stream-error .number-stream-time,
.number-stream-error .number-stream-text {
  color: #fca5a5;
}

.flow-events {
  margin-top: 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  background: rgba(2, 6, 23, 0.28);
  padding: 10rpx 12rpx;
  max-height: 200rpx;
  overflow: hidden;
}

.flow-events-title {
  font-size: 20rpx;
  color: #c7dcff;
  margin-bottom: 8rpx;
  letter-spacing: 0.6rpx;
}

.flow-event-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 6rpx 0;
  border-top: 1rpx solid rgba(148, 163, 184, 0.18);
}

.flow-event-item:first-of-type {
  border-top: none;
}

.flow-event-time {
  flex-shrink: 0;
  font-size: 18rpx;
  color: #a5b4fc;
  min-width: 76rpx;
}

.flow-event-text {
  flex: 1;
  min-width: 0;
  font-size: 20rpx;
  color: #dbeafe;
  line-height: 1.4;
  word-break: break-all;
}

.flow-event-success .flow-event-time,
.flow-event-success .flow-event-text {
  color: #99f6e4;
}

.flow-event-error .flow-event-time,
.flow-event-error .flow-event-text {
  color: #fda4af;
}

.showcase-card {
  background: linear-gradient(145deg, #10233f 0%, #123c63 50%, #164872 100%);
  color: #e2ecff;
  border: 1rpx solid rgba(147, 197, 253, 0.25);
  overflow: hidden;
}

.showcase-card.done {
  box-shadow: 0 10rpx 30rpx rgba(30, 64, 175, 0.22);
}

.showcase-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.showcase-head-left {
  flex: 1;
  min-width: 0;
}

.showcase-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #eff6ff;
}

.showcase-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #bae6fd;
}

.showcase-summary {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #dbeafe;
  line-height: 1.4;
}

.showcase-score-ring {
  width: 146rpx;
  height: 146rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(125, 211, 252, 0.65);
  background: radial-gradient(circle at 30% 30%, rgba(14, 116, 144, 0.4) 0%, rgba(15, 23, 42, 0.35) 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  animation: showcase-score-pulse 1.4s ease-in-out infinite;
}

.showcase-score-value {
  font-size: 46rpx;
  line-height: 1;
  font-weight: 700;
  color: #e0f2fe;
}

.showcase-score-label {
  margin-top: 6rpx;
  font-size: 19rpx;
  color: #cbd5e1;
}

.showcase-pills {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.showcase-pill {
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.32);
  background: rgba(15, 23, 42, 0.28);
  color: #dbeafe;
  font-size: 20rpx;
  display: flex;
  align-items: center;
}

.showcase-model-meta {
  margin-top: 10rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.32);
  background: rgba(2, 6, 23, 0.24);
  padding: 8rpx 12rpx;
}

.showcase-model-line {
  font-size: 20rpx;
  line-height: 1.45;
  color: #dbeafe;
  word-break: break-all;
}

.showcase-model-line.ok {
  color: #99f6e4;
}

.showcase-model-line.error {
  color: #fca5a5;
}

.showcase-comment {
  margin-top: 14rpx;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.3);
  background: rgba(2, 6, 23, 0.24);
}

.showcase-comment-label {
  display: block;
  font-size: 20rpx;
  color: #7dd3fc;
}

.showcase-comment-text {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #eff6ff;
}

.showcase-grid {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.showcase-panel {
  flex: 1 1 calc(50% - 6rpx);
  min-width: 230rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.3);
  background: rgba(15, 23, 42, 0.24);
  padding: 10rpx 12rpx;
  box-sizing: border-box;
}

.showcase-panel-title {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.showcase-panel-title.good {
  color: #86efac;
}

.showcase-panel-title.improve {
  color: #fcd34d;
}

.showcase-item {
  margin-top: 8rpx;
  border-radius: 9rpx;
  padding: 8rpx 10rpx;
  font-size: 20rpx;
  line-height: 1.35;
  animation: showcase-item-in 320ms ease-out;
}

.showcase-item.good {
  color: #dcfce7;
  background: rgba(22, 101, 52, 0.35);
}

.showcase-item.improve {
  color: #fef3c7;
  background: rgba(146, 64, 14, 0.35);
}

.showcase-item.neutral {
  color: #dbeafe;
  background: rgba(30, 64, 175, 0.28);
}

.showcase-tips {
  margin-top: 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(147, 197, 253, 0.28);
  background: rgba(30, 41, 59, 0.24);
  padding: 10rpx 12rpx;
}

.showcase-tips-title {
  display: block;
  font-size: 22rpx;
  color: #93c5fd;
  margin-bottom: 8rpx;
}

.showcase-tip {
  font-size: 20rpx;
  line-height: 1.4;
  color: #e2e8f0;
  margin-top: 6rpx;
}

.page.big-screen {
  background: radial-gradient(circle at 22% -2%, #dbeafe 0%, #eff6ff 35%, #eef2ff 100%);
  padding: 24rpx;
}

.page.big-screen .card {
  border-radius: 18rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.08);
}

.page.big-screen .title {
  font-size: 38rpx;
}

.page.big-screen .desc {
  font-size: 26rpx;
}

.page.big-screen .label,
.page.big-screen .status-meta,
.page.big-screen .hint,
.page.big-screen .json,
.page.big-screen .empty-tip {
  font-size: 24rpx;
}

.page.big-screen .btn {
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
}

.page.big-screen .flow-title {
  font-size: 34rpx;
}

.page.big-screen .flow-progress-value {
  font-size: 52rpx;
}

.page.big-screen .showcase-title {
  font-size: 36rpx;
}

.page.big-screen .showcase-summary {
  font-size: 28rpx;
}

.page.big-screen .showcase-score-ring {
  width: 168rpx;
  height: 168rpx;
}

.page.big-screen .showcase-score-value {
  font-size: 52rpx;
}

@keyframes flow-progress-glow {
  0% {
    opacity: 0.82;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.82;
  }
}

@keyframes flow-dot-blink {
  0% {
    opacity: 0.4;
    transform: scale(0.95);
  }
  50% {
    opacity: 1;
    transform: scale(1.08);
  }
  100% {
    opacity: 0.4;
    transform: scale(0.95);
  }
}

@keyframes flow-bar-pulse {
  0% {
    opacity: 0.42;
  }
  100% {
    opacity: 1;
  }
}

@keyframes stream-line-in {
  0% {
    opacity: 0;
    transform: translateX(-8rpx);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes showcase-score-pulse {
  0% {
    box-shadow: 0 0 0 0 rgba(56, 189, 248, 0.2);
  }
  100% {
    box-shadow: 0 0 0 14rpx rgba(56, 189, 248, 0);
  }
}

@keyframes showcase-item-in {
  0% {
    opacity: 0;
    transform: translateY(8rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.raw-data-container {
