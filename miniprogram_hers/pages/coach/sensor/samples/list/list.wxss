.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 14rpx rgba(15, 23, 42, 0.05);
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.filters {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.filter-item {
  flex: 1;
}

.label {
  display: block;
  font-size: 22rpx;
  color: #475569;
  margin-bottom: 6rpx;
}

.picker-value {
  min-height: 72rpx;
  border-radius: 10rpx;
  border: 1rpx solid #dbe5f0;
  background: #f8fafc;
  font-size: 24rpx;
  color: #1f2937;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.refresh-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 24rpx;
  border-radius: 10rpx;
  background: #1d7df2;
  color: #fff;
}

.state {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #64748b;
}

.error {
  font-size: 24rpx;
  color: #b91c1c;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.item-card {
  margin-bottom: 14rpx;
}

.item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.session {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  word-break: break-all;
}

.source {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #075985;
  background: #e0f2fe;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #334155;
  word-break: break-all;
}

.item-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  background: #e2e8f0 !important;
  color: #1f2937 !important;
}

.danger-btn {
  flex: 1;
  background: #fee2e2 !important;
  color: #b91c1c !important;
}

.detail {
  margin-top: 12rpx;
  border-top: 1rpx solid #e2e8f0;
  padding-top: 8rpx;
}

.load-more {
  margin-top: 6rpx;
  background: #1d7df2;
  color: #fff;
  border-radius: 10rpx;
}

.end-tip {
  text-align: center;
  margin: 10rpx 0 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}
