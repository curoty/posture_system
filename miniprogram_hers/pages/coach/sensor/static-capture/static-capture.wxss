.page { padding: 24rpx; background: #f5f7fa; min-height: 100vh; }
.card { background: #fff; border-radius: 18rpx; padding: 28rpx; margin-bottom: 22rpx; }
.title { font-size: 36rpx; font-weight: 700; margin-bottom: 14rpx; }
.label { font-size: 28rpx; font-weight: 600; margin: 22rpx 0 10rpx; }
.picker { border: 1px solid #dce1e8; border-radius: 12rpx; padding: 20rpx; }
.hint, .status { color: #596273; font-size: 26rpx; line-height: 1.7; }
.primary { margin-top: 28rpx; background: #2563eb; color: #fff; }
.danger { margin-top: 16rpx; background: #fff1f0; color: #c62828; }
.error { margin: 20rpx; padding: 20rpx; background: #fff1f0; color: #c62828; border-radius: 12rpx; }
