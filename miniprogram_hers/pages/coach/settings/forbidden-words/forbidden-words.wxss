.page-scroll {
  width: 100%;
  height: 100vh;
}

.container {
  width: 100%;
  min-height: 100vh;
  background-color: #f2f4f7;
  padding: 20rpx;
  box-sizing: border-box;
}

.search-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e7eb;
  height: 72rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
}

.search-placeholder {
  color: #9ca3af;
}

.refresh-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
  font-size: 32rpx;
  color: #6b7280;
}

.category-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.category-tab {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #6b7280;
  background-color: #fff;
  border-radius: 20rpx;
  border: 1rpx solid #e5e7eb;
}

.category-tab.active {
  background-color: #1989fa;
  color: #fff;
  border-color: #1989fa;
}

.add-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.add-input-wrap {
  flex: 1;
  display: flex;
  gap: 12rpx;
}

.add-input {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #fff;
}

.add-picker {
  width: 140rpx;
}

.add-picker-inner {
  height: 72rpx;
  line-height: 72rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #1f2937;
  background-color: #fff;
  text-align: center;
}

.add-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #1989fa, #0a6cf0);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  padding: 0;
}

.add-btn::after {
  border: none;
}

.word-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.word-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.word-item:last-child {
  border-bottom: none;
}

.word-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.word-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.word-category {
  font-size: 22rpx;
  color: #9ca3af;
  background-color: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.word-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.action-btn.toggle {
  background-color: #fff7e6;
  color: #fa8c16;
  border: 1rpx solid #ffd591;
}

.action-btn.delete {
  background-color: #fff1f0;
  color: #f5222d;
  border: 1rpx solid #ffa39e;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 30rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
}

.loading-tip {
  text-align: center;
  font-size: 28rpx;
  color: #9ca3af;
  padding: 40rpx 0;
}