.container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  box-sizing: border-box;
  background-color: #f5f6fa;
  min-height: 100vh;
  padding-bottom: 30rpx;
}

/* ========== 顶部搜索区域 ========== */
.header-section {
  width: 100%;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  background-color: #f5f6fa;
  border-radius: 38rpx;
  font-size: 28rpx;
  border: none;
  box-sizing: border-box;
}

.add-btn {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 32rpx;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 38rpx;
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
}

/* ========== 内容区 ========== */
.content-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  padding: 0 24rpx;
  box-sizing: border-box;
}

/* ========== 统计卡片 ========== */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx;
  border-radius: 16rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8c8c8c;
}

.stat-total .stat-num {
  color: #1f2937;
}

.stat-assigned .stat-num {
  color: #1890ff;
}

.stat-unassigned .stat-num {
  color: #fa8c16;
}

/* ========== Tab 切换 ========== */
.tab-bar {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.tab-active {
  background-color: #1890ff;
  color: #fff;
  font-weight: 600;
}

/* ========== 学员列表 ========== */
.student-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ========== 学员卡片 ========== */
.student-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 卡片头部：头像 + 姓名/标签 + 手机号 */
.card-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.card-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background-color: #f0f2f5;
}

.card-avatar image {
  width: 100%;
  height: 100%;
}

.card-header-info {
  flex: 1;
  min-width: 0;
}

.card-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.card-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.tag {
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.tag-class {
  background-color: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #91d5ff;
}

.tag-unassigned {
  background-color: #fff7e6;
  color: #fa8c16;
  border: 1rpx solid #ffd591;
}

.card-phone {
  font-size: 26rpx;
  color: #8c8c8c;
}

/* 卡片正文 */
.card-body {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 18rpx;
  margin-bottom: 18rpx;
}

.card-lesson-row {
  margin-bottom: 10rpx;
}

.lesson-text {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: 500;
}

.lesson-text.lesson-none {
  color: #fa8c16;
}

.card-meta-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-label {
  font-size: 24rpx;
  color: #999;
}

.meta-value {
  font-size: 24rpx;
  color: #666;
}

/* 卡片按钮区 */
.card-actions {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.action-btn {
  margin: 0;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: none;
  box-sizing: border-box;
}

/* 设置课时 - 蓝色 */
.btn-set-lesson {
  color: #fff;
  background-color: #1890ff;
}

/* 退出班级 - 红色 */
.btn-exit-class {
  color: #fff;
  background-color: #ff4d4f;
}

/* 移交管理 - 紫色 */
.btn-transfer {
  color: #fff;
  background-color: #722ed1;
}

/* 分班 - 绿色 */
.btn-assign-class {
  color: #fff;
  background-color: #52c41a;
}

/* 删除 - 灰色 */
.btn-delete {
  color: #fff;
  background-color: #8c8c8c;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 88rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}