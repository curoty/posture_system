.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.student-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.period-picker {
  background-color: #fff;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #ddd;
  min-width: 150rpx;
}

.picker-text {
  font-size: 24rpx;
  color: #333;
}

.stats-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background-color: #fff;
  padding: 30rpx 20rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1989fa;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #666;
}

.chart-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.chart-container {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 200rpx;
  gap: 15rpx;
}

.chart-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.chart-date {
  font-size: 18rpx;
  color: #999;
}

.chart-bar-container {
  width: 100%;
  height: 150rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.chart-bar {
  width: 100%;
  background-color: #1989fa;
  border-radius: 4rpx;
  transition: height 0.3s ease;
}

.chart-score {
  font-size: 18rpx;
  font-weight: bold;
  color: #333;
}

.intensity-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.intensity-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.intensity-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.intensity-label {
  font-size: 20rpx;
  color: #666;
  width: 40rpx;
}

.intensity-bar-container {
  flex: 1;
  height: 20rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}

.intensity-bar {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.intensity-bar.low {
  background-color: #07C160;
}

.intensity-bar.medium {
  background-color: #ff9500;
}

.intensity-bar.high {
  background-color: #ff3b30;
}

.intensity-value {
  font-size: 20rpx;
  color: #333;
  font-weight: bold;
  width: 60rpx;
  text-align: right;
}

.training-summary {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.summary-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.recommendations {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.recommendation-item {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.recommendation-icon {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.recommendation-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  flex: 1;
}
