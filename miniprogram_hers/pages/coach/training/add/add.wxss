.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.picker-text {
  font-size: 24rpx;
  color: #333;
}

.batch-tip {
  display: block;
  margin-bottom: 16rpx;
  font-size: 22rpx;
  color: #666;
}

.form-group {
  margin-bottom: 25rpx;
}

.form-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #ddd;
  font-size: 24rpx;
  color: #333;
}

.form-textarea {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #ddd;
  font-size: 24rpx;
  color: #333;
  min-height: 120rpx;
  resize: none;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background-color: #1989fa;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-top: 20rpx;
}
