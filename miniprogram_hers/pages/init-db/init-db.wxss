.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 20rpx;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 60rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 40rpx;
  width: 100%;
  max-width: 600rpx;
}

.loading {
  text-align: center;
  width: 100%;
}

.result {
  text-align: center;
  width: 100%;
}

.message {
  font-size: 28rpx;
  line-height: 44rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.progress-list {
  width: 100%;
  margin-top: 20rpx;
  max-height: 300rpx;
  overflow-y: auto;
}

.progress-item {
  display: block;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #888;
  text-align: left;
  margin-bottom: 8rpx;
}

.footer {
  width: 100%;
  max-width: 600rpx;
}

.btn {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 16rpx;
}
