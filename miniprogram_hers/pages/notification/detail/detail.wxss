.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eaf8ff 0%, #f7fbff 24%, #f7fafc 100%);
}

.card {
  background-color: #fff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.06);
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meta-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-shell {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  background: #eafbf2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon {
  width: 46rpx;
  height: 46rpx;
}

.meta-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tag {
  font-size: 22rpx;
  line-height: 1.2;
  color: #35c66b;
  font-weight: 700;
}

.sender {
  font-size: 24rpx;
  line-height: 1.3;
  color: #8a98a8;
}

.time {
  font-size: 22rpx;
  color: #9aa6b2;
  white-space: nowrap;
}

.title {
  display: block;
  margin-top: 22rpx;
  font-size: 36rpx;
  line-height: 1.35;
  color: #1f2933;
  font-weight: 800;
}

.content {
  display: block;
  margin-top: 24rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #51606f;
  white-space: pre-wrap;
}
