.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #eaf8ff 0%, #f7fbff 24%, #f7fafc 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.page-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.head-copy {
  flex: 1;
  min-width: 0;
}

.head-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.head-clear {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 42, 0.06);
  opacity: 0.55;
  transform: scale(1);
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.head-clear.is-active {
  opacity: 1;
}

.head-clear.is-loading {
  opacity: 0.6;
  transform: scale(0.96);
}

.head-clear-icon {
  width: 42rpx;
  height: 42rpx;
}

.head-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #1f2933;
}

.head-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #8a98a8;
}

.head-badge {
  min-width: 72rpx;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(31, 45, 42, 0.06);
  box-sizing: border-box;
}

.head-badge-text {
  font-size: 24rpx;
  line-height: 1;
  color: #35c66b;
  font-weight: 800;
}

.loading-tip,
.error-tip {
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.loading-tip {
  background-color: #fff;
  color: #66727f;
}

.error-tip {
  background-color: #fff2f0;
  color: #c53030;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background-color: #fff;
  border-radius: 28rpx;
  padding: 22rpx 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.item.is-unread {
  border: 1rpx solid #e8f3ee;
}

.item.is-read {
  opacity: 0.92;
}

.item-icon-shell {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.accent-report .item-icon-shell {
  background: #ecfbf2;
}

.accent-course .item-icon-shell {
  background: #eef8ff;
}

.accent-reminder .item-icon-shell {
  background: #fff8e8;
}

.accent-reward .item-icon-shell {
  background: #fff2f7;
}

.accent-system .item-icon-shell {
  background: #f1f5f9;
}

.item-icon {
  width: 52rpx;
  height: 52rpx;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.item-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 1.3;
  color: #1f2933;
  font-weight: 800;
}

.item-time {
  flex-shrink: 0;
  font-size: 20rpx;
  line-height: 1.2;
  color: #9aa6b2;
}

.item-summary {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  color: #66727f;
}

.item-foot {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.item-tag {
  font-size: 20rpx;
  line-height: 1.2;
  color: #35c66b;
  background: #eafbf2;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.item-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #35c66b;
}

.item-arrow {
  flex-shrink: 0;
  width: 28rpx;
  height: 28rpx;
  opacity: 0.5;
}

.empty {
  min-height: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.empty-icon {
  width: 84rpx;
  height: 84rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #4b5866;
  font-weight: 700;
}

.empty-tip {
  font-size: 22rpx;
  color: #97a3af;
}

@media (max-width: 375px) {
  .container {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }

  .item {
    padding: 20rpx 18rpx;
    gap: 16rpx;
  }

  .item-icon-shell {
    width: 80rpx;
    height: 80rpx;
  }
}
