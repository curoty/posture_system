.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
  padding-bottom: 80rpx;
}

.header {
  padding: 20rpx 8rpx 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1f2937;
  display: block;
}

.header-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #94a3b8;
  display: block;
}

.phase-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.phase-steps {
  display: flex;
  align-items: center;
  justify-content: center;
}

.phase-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #e5e7eb;
  transition: all 0.3s;
}

.phase-step.active .step-dot {
  background: #2563eb;
  box-shadow: 0 0 10rpx rgba(37,99,235,0.5);
  animation: dot-pulse 1s ease-in-out infinite;
}

.phase-step.done .step-dot {
  background: #22c55e;
}

.step-label {
  font-size: 20rpx;
  color: #d1d5db;
  font-weight: 600;
}

.phase-step.done .step-label {
  color: #22c55e;
}

.phase-step.active .step-label {
  color: #2563eb;
}

.step-line {
  flex: 1;
  height: 3rpx;
  background: #e5e7eb;
  margin: 0 8rpx;
  margin-bottom: 22rpx;
  transition: background 0.3s;
}

.step-line.active {
  background: #22c55e;
}

@keyframes dot-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.3); }
}

.action-area {
  margin-top: 24rpx;
}

.main-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  border: none;
  padding: 0;
  box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.3);
}

.status-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.status-ring {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #e5e7eb;
  border-top-color: #2563eb;
  animation: spin 0.8s linear infinite;
}

.status-ring.connecting {
  border-color: #bfdbfe;
  border-top-color: #2563eb;
}

.status-ring.analyzing {
  border-color: #d1fae5;
  border-top-color: #22c55e;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.collect-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f0fdf4;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.ring-wave {
  position: absolute;
  inset: -8rpx;
  border-radius: 50%;
  border: 3rpx solid #22c55e;
  animation: wave-pulse 1.5s ease-out infinite;
}

@keyframes wave-pulse {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(1.2); opacity: 0; }
}

.ring-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #16a34a;
  z-index: 1;
}

.status-text {
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.status-hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.result-section {
  margin-top: 24rpx;
}

.result-card {
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  margin-bottom: 20rpx;
}

.score-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.score-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #e2e8f0;
  flex-shrink: 0;
}

.score-circle.excellent { border-color: #34d399; background: #ecfdf5; }
.score-circle.excellent .score-number { color: #059669; }
.score-circle.good { border-color: #60a5fa; background: #eff6ff; }
.score-circle.good .score-number { color: #2563eb; }
.score-circle.mid { border-color: #fbbf24; background: #fffbeb; }
.score-circle.mid .score-number { color: #d97706; }
.score-circle.fail { border-color: #f87171; background: #fef2f2; }
.score-circle.fail .score-number { color: #dc2626; }

.score-number {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
}

.score-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #94a3b8;
}

.score-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.quality-badge {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
}

.quality-badge.excellent { background: #ecfdf5; color: #059669; }
.quality-badge.good { background: #eff6ff; color: #2563eb; }
.quality-badge.mid { background: #fffbeb; color: #d97706; }
.quality-badge.fail { background: #fef2f2; color: #dc2626; }

.quality-badge text {
  font-size: 28rpx;
  font-weight: 700;
}

.confidence-text {
  font-size: 24rpx;
  color: #94a3b8;
}

.comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.voice-btn {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 600;
}

.voice-btn.playing {
  background: #fef2f2;
  border-color: #fecaca;
  color: #dc2626;
}

.comment-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
}

.save-row {
  display: flex;
  gap: 16rpx;
}

.save-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #35c66b 0%, #2db85f 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  padding: 0;
}

.reset-btn {
  width: 180rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
}

.error-tip {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: #fef2f2;
  border: 1rpx solid #fecaca;
}

.error-tip text {
  font-size: 26rpx;
  color: #dc2626;
  line-height: 1.6;
}

.status-bar {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: white;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.status-item {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
  font-size: 28rpx;
}

.status-item:last-child {
  margin-bottom: 0;
}

.status-item .label {
  color: #666;
  width: 100rpx;
}

.status-item .value {
  color: #333;
  font-weight: 500;
  flex: 1;
}

.status-disconnected {
  color: #999 !important;
}

.status-connecting {
  color: #ff9500 !important;
}

.status-connected {
  color: #07c160 !important;
}

.frame-count {
  color: #1989fa !important;
  font-size: 36rpx;
  font-weight: 600;
}

.btn-group {
  margin-top: 24rpx;
}

.btn {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 20rpx 0;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: white;
}

.btn.secondary {
  background: white;
  color: #1989fa;
  border: 2rpx solid #1989fa;
}

.btn.success {
  background: #07c160;
  color: white;
}

.btn.disabled-success {
  background: #e5e5e5;
  color: #999;
}

.btn.danger {
  background: #fa5151;
  color: white;
}

.btn.warn {
  background: #ff9500;
  color: white;
}

.btn.disabled-warn {
  background: #e5e5e5;
  color: #999;
}

.btn[disabled] {
  opacity: 1;
  color: #999 !important;
}

.logs-container {
  margin-top: 20rpx;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.logs-title {
  background: #f7f8fa;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  border-bottom: 1rpx solid #eee;
}

.logs-content {
  height: 240rpx;
  padding: 16rpx 24rpx;
}

.log-item {
  font-size: 22rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8rpx;
  font-family: 'Courier New', monospace;
  word-break: break-all;
}
