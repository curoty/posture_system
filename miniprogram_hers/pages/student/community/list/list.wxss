page {
  background: #ffffff;
  overflow-x: hidden;
}

.community-page {
  min-height: 100vh;
  width: 100vw;
  padding: 18rpx 32rpx 0;
  padding-top: calc(18rpx + constant(safe-area-inset-top));
  padding-top: calc(18rpx + env(safe-area-inset-top));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #effcff 0%, #f9fdff 18%, #ffffff 52%, #f7fbff 100%);
  overflow-x: hidden;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
  flex-shrink: 0;
}

.search-box {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f6f8fb;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 76rpx;
  color: #1f2933;
  font-size: 26rpx;
}

.search-placeholder {
  color: #a6b0ba;
}

.search-btn {
  width: 92rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #35c66b;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 76rpx;
  text-align: center;
  font-weight: 700;
  flex-shrink: 0;
}

.plus-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #1f2933;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.plus-text {
  color: #ffffff;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
}

.category-tabs {
  display: flex;
  align-items: flex-end;
  gap: 34rpx;
  padding: 8rpx 0 18rpx;
  flex-shrink: 0;
}

.category-tab {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.category-text {
  color: #5f6c79;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 700;
}

.category-tab.active .category-text {
  color: #35c66b;
}

.category-bar {
  width: 34rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #35c66b;
}

.post-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  background: #ffffff;
}

.video-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
  width: 100%;
  min-height: 100%;
  background: #ffffff;
}

.video-card {
  width: calc((100% - 22rpx) / 2);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.cover-wrap {
  position: relative;
  width: 100%;
  height: 286rpx;
  padding: 12rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.video-cover,
.video-placeholder,
.cover-overlay {
  position: absolute;
  inset: 12rpx;
  width: auto;
  height: auto;
  border-radius: 24rpx;
  display: block;
}

.video-placeholder {
  background: linear-gradient(135deg, #dff7ff 0%, #eafbf2 100%);
}

.cover-overlay {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0.18) 100%);
  pointer-events: none;
}

.play-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 64rpx;
  height: 64rpx;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.video-duration {
  position: absolute;
  right: 24rpx;
  bottom: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.62);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 700;
}

.video-body {
  display: block;
  padding: 0 18rpx 20rpx;
}

.video-title {
  color: #1f2933;
  font-size: 29rpx;
  line-height: 1.4;
  font-weight: 800;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.author-info {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #eafbf2;
  flex-shrink: 0;
}

.author-name {
  color: #8a98a8;
  font-size: 22rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
}

.author-role-tag {
  flex-shrink: 0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 18rpx;
  line-height: 1.3;
  font-weight: 600;
}

.author-role-tag.coach {
  color: #ffffff;
  background-color: #52c41a;
}

.video-stats {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.video-stat {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-mini-icon {
  width: 24rpx;
  height: 24rpx;
}

.video-stat-text {
  color: #8a98a8;
  font-size: 21rpx;
  line-height: 1.2;
}

.empty-state {
  padding: 42rpx 0 24rpx;
  text-align: center;
}

.empty-text {
  color: #4b5866;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
}

.list-bottom-safe {
  height: calc(170rpx + env(safe-area-inset-bottom));
}

@media (max-width: 375px) {
  .community-page {
    padding-left: 28rpx;
    padding-right: 28rpx;
  }

  .category-tabs {
    gap: 28rpx;
  }

  .video-grid {
    gap: 18rpx;
  }

  .video-card {
    width: calc((100% - 18rpx) / 2);
  }

  .cover-wrap {
    height: 268rpx;
  }
}

.video-actions {
  display: flex;
  gap: 10rpx;
  padding: 0 18rpx 14rpx;
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  min-width: 0;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  padding: 0;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.action-detail {
  background: #eaf4ff;
  color: #49bdf5;
  border: 2rpx solid #d6eaff;
}

.action-delete {
  background: #fff3f2;
  color: #f45b5b;
  border: 2rpx solid #ffd7d4;
}

.action-btn[disabled] {
  opacity: 0.5;
}
