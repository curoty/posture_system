.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #ddf6ff 0%, #eaf9ff 32%, #ffffff 78%);
  padding: 34rpx 30rpx 60rpx;
  padding-top: calc(34rpx + constant(safe-area-inset-top));
  padding-top: calc(34rpx + env(safe-area-inset-top));
  box-sizing: border-box;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  text-align: center;
  margin-bottom: 56rpx;
}

.header-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 16rpx;
}

.header-title {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #1f2933;
  margin-bottom: 12rpx;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: #8a98a8;
  line-height: 1.5;
}

.input-section {
  width: 100%;
  max-width: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.input-group {
  width: 100%;
  padding: 32rpx 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.input-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2933;
  margin-bottom: 24rpx;
}

.code-input-wrapper {
  width: 100%;
  text-align: center;
  margin-bottom: 18rpx;
}

.code-input {
  width: 360rpx;
  height: 88rpx;
  border: 2rpx solid #e0e7ee;
  border-radius: 16rpx;
  background: #f7fbff;
  text-align: center;
  font-size: 48rpx;
  font-weight: 800;
  color: #35c66b;
  letter-spacing: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.code-input:focus {
  border-color: #35c66b;
}

.input-hint {
  font-size: 22rpx;
  color: #8a98a8;
  text-align: center;
}

.btn-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.join-btn {
  width: 320rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #35c66b 0%, #20c76a 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 24rpx rgba(53, 198, 107, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.join-btn::after {
  border: none;
}

.join-btn[disabled] {
  background: #c8d6e0;
  box-shadow: none;
  color: #ffffff;
}

.scan-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 32rpx;
  border-radius: 44rpx;
  border: 2rpx solid #35c66b;
}

.scan-icon {
  font-size: 32rpx;
}

.scan-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #35c66b;
}

.result-section {
  width: 100%;
  max-width: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1f2933;
  margin-bottom: 14rpx;
}

.result-desc {
  font-size: 26rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 40rpx;
}

.result-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  align-items: center;
}

.result-btn {
  width: 280rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-btn::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #35c66b 0%, #20c76a 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(53, 198, 107, 0.25);
}

.secondary-btn {
  background: #f2f4f7;
  color: #64748b;
}
