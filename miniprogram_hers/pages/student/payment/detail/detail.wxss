.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding-bottom: 140rpx;
}

.image-section {
  width: 100%;
  height: 520rpx;
  background: #fff;
}

.goods-banner {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
}

.info-section {
  margin: -24rpx 24rpx 0;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 2;
}

.goods-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2933;
  line-height: 1.35;
  display: block;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 18rpx;
}

.price-current {
  font-size: 44rpx;
  font-weight: 800;
  color: #ff5a4f;
}

.price-original {
  font-size: 26rpx;
  color: #a6b0ba;
  text-decoration: line-through;
}

.meta-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.meta-tag {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #f0f5ff;
  color: #3b82f6;
}

.meta-tag.status-active {
  background: #e6f9ec;
  color: #16a34a;
}

.meta-tag.status-stock {
  background: #fff7e6;
  color: #d97706;
}

.desc-section {
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #fff;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2933;
  margin-bottom: 16rpx;
  display: block;
}

.desc-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 96rpx;
  padding: 0 24rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.04);
  box-sizing: border-box;
  z-index: 100;
}

.bottom-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  flex-shrink: 0;
}

.bottom-price-label {
  font-size: 24rpx;
  color: #a6b0ba;
}

.bottom-price-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #ff5a4f;
  line-height: 1;
}

.contact-btn {
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #35c66b 0%, #2db85f 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  border: none;
  padding: 0 40rpx;
  flex-shrink: 0;
}

.empty-state {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
}
