.mall-page {
  min-height: 100vh;
  padding: 20rpx 32rpx 170rpx;
  padding-top: calc(20rpx + constant(safe-area-inset-top));
  padding-top: calc(20rpx + env(safe-area-inset-top));
  padding-bottom: calc(170rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f7fafc;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.search-box {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f4f7fa;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 76rpx;
  color: #1f2933;
  font-size: 26rpx;
}

.search-placeholder {
  color: #a6b0ba;
}

.search-btn {
  width: 92rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #35c66b;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 76rpx;
  text-align: center;
  font-weight: 700;
  flex-shrink: 0;
}

.cart-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
}

.cart-icon {
  width: 34rpx;
  height: 34rpx;
}

.error-tip {
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  color: #b42318;
  background: #fff1f0;
  border: 1rpx solid #ffccc7;
  font-size: 24rpx;
}

.promo-banner {
  position: relative;
  height: 258rpx;
  margin-bottom: 28rpx;
  padding: 24rpx 24rpx 24rpx 28rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: 0 12rpx 26rpx rgba(73, 189, 245, 0.16);
}

.promo-bg,
.promo-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.promo-mask {
  background: linear-gradient(90deg, rgba(33, 168, 95, 0.9) 0%, rgba(53, 198, 107, 0.72) 42%, rgba(73, 189, 245, 0.16) 100%);
}

.promo-copy {
  position: relative;
  z-index: 2;
  width: 54%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.promo-title {
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 800;
}

.promo-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 600;
}

.promo-btn {
  margin-top: 28rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #ffd765;
  color: #7b5a00;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 800;
}

.promo-kid {
  position: absolute;
  right: -4rpx;
  bottom: -6rpx;
  width: 248rpx;
  height: 238rpx;
  z-index: 2;
}

.category-grid {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.category-item {
  width: 20%;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  border-radius: 18rpx;
  padding: 8rpx 0;
  box-sizing: border-box;
}

.category-item.active {
  background: #eafbf2;
}

.category-icon {
  width: 76rpx;
  height: 76rpx;
}

.category-label {
  color: #2f3944;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 600;
  white-space: nowrap;
}

.category-item.active .category-label {
  color: #35c66b;
  font-weight: 800;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #1f2933;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 800;
}

.section-more {
  color: #8a98a8;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 600;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.goods-card {
  width: calc((100% - 18rpx) / 2);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.goods-image-wrap {
  height: 230rpx;
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #ffffff 0%, #f6fbff 100%);
}

.goods-image {
  width: 100%;
  height: 100%;
  display: block;
}

.goods-body {
  padding: 0 18rpx 18rpx;
}

.goods-title {
  min-height: 70rpx;
  color: #1f2933;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-price {
  margin-top: 12rpx;
  color: #ff5a4f;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 800;
  display: block;
}

.empty-tip-row {
  padding: 28rpx 0 0;
  text-align: center;
}

.empty-tip {
  color: #8a98a8;
  font-size: 22rpx;
}

@media (max-width: 375px) {
  .mall-page {
    padding-left: 28rpx;
    padding-right: 28rpx;
  }

  .promo-banner {
    height: 240rpx;
    padding-right: 16rpx;
  }

  .promo-title {
    font-size: 38rpx;
  }

  .promo-kid {
    width: 224rpx;
    height: 216rpx;
  }

  .category-icon {
    width: 68rpx;
    height: 68rpx;
  }

  .category-label {
    font-size: 21rpx;
  }
}
