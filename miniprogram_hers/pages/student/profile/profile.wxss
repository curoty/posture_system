.profile-page {
  min-height: 100vh;
  background: #f7fafc;
}

.hero-shell {
  min-height: 430rpx;
  padding: 22rpx 32rpx 156rpx;
  padding-top: calc(22rpx + constant(safe-area-inset-top));
  padding-top: calc(22rpx + env(safe-area-inset-top));
  box-sizing: border-box;
  background: linear-gradient(135deg, #ddf8e8 0%, #7ddea0 100%);
}

.hero-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.topbar-spacer {
  width: 88rpx;
  height: 88rpx;
}

.settings-button {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.settings-icon {
  width: 42rpx;
  height: 42rpx;
}

.hero-main {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.avatar-wrap {
  width: 136rpx;
  height: 136rpx;
  padding: 6rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.94);
  box-sizing: border-box;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 50%;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding-top: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-name {
  max-width: 100%;
  color: #1f2933;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-role {
  margin-top: 12rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #ffe58a;
  color: #8c6a10;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
  line-height: 1.35;
}

.content-shell {
  margin-top: -86rpx;
  padding: 0 24rpx 170rpx;
  padding-bottom: calc(170rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ========== 统计卡片：一行两列 ========== */
.stats-card {
  margin-top: 24rpx;
  padding: 32rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.stats-grid {
  display: flex;
}

.stats-grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 120rpx;
}

.stats-grid-item:first-child {
  align-items: flex-start;
}

.stats-grid-item:last-child {
  align-items: center;
}

.stats-value {
  color: #1f2933;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.1;
}

.stats-label-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.stats-label {
  color: #8a98a8;
  font-size: 24rpx;
  line-height: 1.2;
}

.stats-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}
/* ========== 统计卡片结束 ========== */

.section-card {
  margin-top: 28rpx;
  padding: 0 28rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.04);
}

/* ========== 信息列表：左右对齐，不居中 ========== */
.info-row,
.action-row,
.phone-action-row {
  min-height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between; /* 两端对齐 */
  gap: 20rpx;
  border-bottom: 1rpx solid #eef0f3;
  padding: 0 4rpx; /* 微调内边距 */
}

.info-row:last-child,
.action-row:last-child,
.phone-action-row:last-child {
  border-bottom: none;
}

.info-left {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0; /* 防止标题被压缩 */
}

.info-icon {
  width: 38rpx;
  height: 38rpx;
  flex-shrink: 0;
}

.info-title {
  color: #606b78;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 600;
  white-space: nowrap; /* 标题不换行 */
}

.info-value {
  color: #7b8490;
  font-size: 28rpx;
  line-height: 1.3;
  text-align: right;
  flex-shrink: 0; /* 值不压缩 */
  max-width: 60%; /* 避免太长溢出，可根据需要调整 */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-title {
  color: #1f2933;
}

.logout-title {
  color: #f45b5b;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.phone-action-row .action-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.action-phone-text {
  color: #7b8490;
  font-size: 26rpx;
  line-height: 1.3;
}
/* ========== 信息列表结束 ========== */

/* ========== 适配小屏 ========== */
@media (max-width: 375px) {
  .hero-shell {
    min-height: 406rpx;
    padding-left: 28rpx;
    padding-right: 28rpx;
    padding-bottom: 148rpx;
  }

  .content-shell {
    margin-top: -78rpx;
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .avatar-wrap {
    width: 128rpx;
    height: 128rpx;
  }

  .hero-name {
    font-size: 37rpx;
  }

  .hero-subtitle {
    font-size: 24rpx;
  }

  /* 小屏统计卡片间距微调 */
  .stats-grid {
    gap: 12rpx;
  }
  .stats-grid-item {
    padding: 16rpx 0;
    min-height: 90rpx;
  }
  .stats-value {
    font-size: 38rpx;
  }
  .stats-label {
    font-size: 22rpx;
  }

  .info-title,
  .info-value {
    font-size: 26rpx;
  }
}