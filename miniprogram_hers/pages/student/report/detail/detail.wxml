<view class="page">
  <view class="report-detail-page">
    <view wx:if="{{loading}}" class="state-card">
      <text class="state-text">正在加载报告详情...</text>
    </view>

    <view wx:if="{{loadError}}" class="state-card error-card">
      <text class="state-text error-text">{{loadError}}</text>
    </view>

    <view wx:if="{{!loading && report}}" class="report-shell">
      <view class="hero-card">
        <text class="hero-eyebrow">训练报告</text>
        <text class="hero-title">{{report.title}}</text>
        <text class="hero-time">{{report.createdAtText}}</text>

        <view class="flower-card">
          <view>
            <text class="flower-label">本次获得小红花</text>
            <text class="flower-value">{{report.flowerText}}</text>
          </view>
          <text wx:if="{{report.flowerIcons}}" class="flower-icons">{{report.flowerIcons}}</text>
        </view>
      </view>

      <view class="info-card">
        <text class="section-title">课程信息</text>

        <view class="info-item">
          <text class="info-label">课程名字</text>
          <text class="info-value">{{report.title}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">上课时间</text>
          <text class="info-value">{{report.courseTime}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">教练名字</text>
          <text class="info-value">{{report.coachName}}</text>
        </view>
      </view>

      <view class="comment-card">
        <text class="section-title">教练评语</text>
        <text class="comment-text">{{report.coachComment || '教练暂时还没有填写评语。'}}</text>
      </view>
    </view>
  </view>
</view>
