page {
  background: linear-gradient(180deg, #eaf8ff 0%, #f5fbff 28%, #f7fbff 46%, #ffffff 100%);
}

.page {
  min-height: 100vh;
}

.schedule-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
}

.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 28rpx 26rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #35c66b 0%, #59d892 52%, #6fd8c0 100%);
  box-shadow: 0 16rpx 36rpx rgba(53, 198, 107, 0.18);
}

.hero-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.hero-eyebrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.hero-title {
  margin-top: 10rpx;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.88);
}

.hero-art {
  width: 164rpx;
  height: 164rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-icon {
  width: 110rpx;
  height: 110rpx;
}

.package-card,
.section-card,
.state-card {
  margin-top: 22rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(22, 55, 94, 0.06);
}

.package-card {
  display: flex;
  align-items: stretch;
  padding: 20rpx 10rpx;
}

.package-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.package-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #1f2933;
}

.package-label {
  font-size: 22rpx;
  color: #8a98a8;
}

.package-divider {
  width: 2rpx;
  margin: 12rpx 0;
  background: #edf1f5;
  border-radius: 999rpx;
}

.state-card {
  padding: 32rpx 28rpx;
  text-align: center;
}

.state-text {
  font-size: 24rpx;
  color: #8a98a8;
}

.error-card {
  border: 2rpx solid #ffd8d6;
}

.error-text {
  color: #ea5b52;
}

.retry-btn {
  margin-top: 18rpx;
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: #35c66b;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.section-card {
  padding: 28rpx 24rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #1f2933;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a98a8;
}

.schedule-list,
.booking-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.schedule-card,
.booking-card {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f9fcff;
  border: 2rpx solid #edf4f8;
}

.booking-card {
  flex-direction: column;
  gap: 18rpx;
}

.schedule-card {
  flex-direction: column;
  gap: 18rpx;
}

.schedule-top,
.booking-top {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
}

.date-badge {
  width: 116rpx;
  min-height: 124rpx;
  padding: 18rpx 12rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ecfff2 0%, #ddf7e8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.booking-date {
  min-height: 118rpx;
}

.date-badge-day {
  font-size: 30rpx;
  font-weight: 800;
  color: #1f2933;
}

.date-badge-week {
  font-size: 22rpx;
  color: #35c66b;
  font-weight: 700;
}

.schedule-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.schedule-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.schedule-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #1f2933;
}

.schedule-status {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
}

.status-open {
  background: #eafbf2;
  color: #35c66b;
}

.status-closed,
.status-completed {
  background: #f1f4f7;
  color: #8a98a8;
}

.status-cancelled {
  background: #fff1f0;
  color: #f45b5b;
}

.status-pending {
  background: #eafbf2;
  color: #35c66b;
}

.status-active {
  background: #eef7ff;
  color: #49bdf5;
}

.schedule-time {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2933;
}

.schedule-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8a98a8;
}

.booking-count-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 18rpx;
  margin-top: 8rpx;
}

.booking-count-text {
  font-size: 22rpx;
  line-height: 1.6;
  color: #8a98a8;
}

.schedule-action {
  display: flex;
  align-items: stretch;
  width: 100%;
}

.book-btn {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #35c66b;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 20rpx rgba(53, 198, 107, 0.2);
}

.book-btn.disabled {
  background: #eef1f4;
  color: #9aa6b2;
  box-shadow: none;
}

.count-pill {
  min-width: 132rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: #f2fbf5;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.count-value {
  font-size: 26rpx;
  font-weight: 800;
  color: #35c66b;
}

.count-subvalue {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #1f2933;
}

.count-label {
  font-size: 20rpx;
  color: #8a98a8;
}

.cancel-btn {
  width: 100%;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 999rpx;
  background: #fff3f2;
  color: #f45b5b;
  border: 2rpx solid #ffd7d4;
  font-size: 24rpx;
  font-weight: 700;
}

.empty-block {
  padding: 34rpx 18rpx 20rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2933;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #8a98a8;
}
